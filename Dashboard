var TASKS_KEY = 'krw_tasks_v1';
var tasks = (function(){
  try { var s = localStorage.getItem(TASKS_KEY); if(s) return JSON.parse(s); } catch(e){}
  return [];
})();
var tasksOpen = true;

function taskSave() { try { localStorage.setItem(TASKS_KEY, JSON.stringify(tasks)); } catch(e){} }
function taskNextId() { return tasks.length ? Math.max.apply(null, tasks.map(function(t){return t.id;})) + 1 : 1; }

function toggleTasks() {
  tasksOpen = !tasksOpen;
  var body = document.getElementById('tasks-body');
  var chev = document.getElementById('tasks-chev');
  if (body) body.style.display = tasksOpen ? '' : 'none';
  if (chev) chev.textContent = tasksOpen ? '▼' : '▶';
}

function addTask() {
  var inp = document.getElementById('task-inp');
  var txt = inp ? inp.value.trim() : '';
  if (!txt) return;
  tasks.push({
    id: taskNextId(),
    text: txt,
    priority: document.getElementById('task-pri-sel').value,
    due: document.getElementById('task-due-inp').value,
    done: false
  });
  inp.value = '';
  document.getElementById('task-due-inp').value = '';
  taskSave();
  renderTasks();
}

function toggleTask(id) {
  var t = tasks.find(function(x){return x.id===id;});
  if (t) t.done = !t.done;
  taskSave(); renderTasks();
}

function deleteTask(id) {
  tasks = tasks.filter(function(x){return x.id!==id;});
  taskSave(); renderTasks();
}

function clearDone() {
  tasks = tasks.filter(function(t){return !t.done;});
  taskSave(); renderTasks();
}

function renderTasks() {
  var list = document.getElementById('tasks-list');
  var badge = document.getElementById('tasks-badge');
  var doneEl = document.getElementById('tasks-done');
  if (!list) return;
  var today = new Date().toISOString().split('T')[0];
  var open = tasks.filter(function(t){return !t.done;});
  var done = tasks.filter(function(t){return t.done;});
  if (badge) badge.textContent = open.length + ' open';
  if (doneEl) doneEl.textContent = done.length > 0 ? done.length + ' completed' : '';
  if (!tasks.length) {
    list.innerHTML = '<div class="tasks-empty">No tasks yet — add one above</div>';
    return;
  }
  var sorted = tasks.slice().sort(function(a,b){
    if (a.done !== b.done) return a.done ? 1 : -1;
    var p = {high:0,normal:1,low:2};
    if (p[a.priority] !== p[b.priority]) return p[a.priority] - p[b.priority];
    if (a.due && b.due) return a.due.localeCompare(b.due);
    if (a.due) return -1; if (b.due) return 1;
    return 0;
  });
  list.innerHTML = '';
  sorted.forEach(function(t) {
    var od = t.due && t.due < today && !t.done;
    var d = document.createElement('div');
    d.className = 'task-item' + (t.done ? ' done' : '');
    d.innerHTML =
      '<input type="checkbox" class="task-cb" ' + (t.done?'checked':'') + ' onchange="toggleTask('+t.id+')">' +
      '<span class="task-lbl">' + t.text + '</span>' +
      (t.priority==='high' ? '<span class="task-pri high">High</span>' : '') +
      (t.priority==='low'  ? '<span class="task-pri low">Low</span>'  : '') +
      (t.due ? '<span class="task-due'+(od?' od':'')+'">'+t.due+'</span>' : '') +
      '<button class="task-del" onclick="deleteTask('+t.id+')">×</button>';
    list.appendChild(d);
  });
}

