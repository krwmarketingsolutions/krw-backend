function renderVerticalBars(elId, rows){
  var el = document.getElementById(elId);
  if(!el) return;
  if(!rows.length){
    el.innerHTML = '<div class="empty-feed">No data yet — waiting for calls</div>';
    return;
  }
  // Support both old (revenue) and new (total_revenue, payout_amount) field names
  var maxRev = Math.max.apply(null, rows.map(function(r){
    return parseFloat(r.revenue || r.total_revenue || r.payout_amount || 0);
  })) || 1;
  el.innerHTML = '';
  rows.forEach(function(r){
    var vert  = r.vertical || '—';
    var rev   = parseFloat(r.revenue || r.total_revenue || r.payout_amount || 0);
    var calls = parseInt(r.calls || r.total_calls || 0);
    var pct   = Math.round(rev / maxRev * 100);
    var color = REV_VERT_COLORS[vert] || '#888780';
    var row   = document.createElement('div');
    row.className = 'vert-row';
    row.innerHTML =
      '<span class="vert-dot" style="background:'+color+'"></span>'+
      '<span class="vert-name">'+vert+'</span>'+
      '<div class="vert-bar-bg"><div class="vert-bar" style="width:'+pct+'%;background:'+color+'"></div></div>'+
      '<span class="vert-calls">'+calls+' call'+(calls!==1?'s':'')+'</span>'+
      '<span class="vert-rev">$'+rev.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})+'</span>';
    el.appendChild(row);
  });
}

