<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>KRW Deal Dashboard</title>
<style>

  :root {
    --bg:#f7f7f5;--surface:#fff;--border:#e8e6e1;--border-mid:#d4d1ca;
    --text:#1a1a18;--muted:#888780;--subtle:#f2f0eb;
    --green:#3B6D11;--green-bg:#EAF3DE;--green-mid:#c0dd97;--green-text:#27500A;
    --orange:#854F0B;--orange-bg:#FEF0DC;--orange-mid:#FAC775;--orange-text:#633806;
    --red:#A32D2D;--blue:#185FA5;
    --radius:10px;--radius-sm:6px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Georgia','Times New Roman',serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}

  /* SIDEBAR */
  .sidebar-brand{padding:1.25rem 1.25rem 1rem;border-bottom:1px solid var(--border)}
  .sidebar-brand .krw-logo{font-family:'Helvetica Neue',Arial,sans-serif;font-size:22px;font-weight:700;letter-spacing:.04em;color:var(--green);margin-bottom:3px}
  .sidebar-brand h1{font-size:12px;font-weight:normal;color:var(--text);letter-spacing:.01em;line-height:1.4}
  .sidebar-brand p{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);margin-top:2px}
  .nav{padding:.75rem 0}
  .nav-item{font-family:'Helvetica Neue',Arial,sans-serif;display:flex;align-items:center;gap:10px;padding:9px 1.25rem;font-size:13px;color:var(--muted);cursor:pointer;transition:all .15s;border-left:2px solid transparent}
  .nav-item:hover{color:var(--text);background:var(--subtle)}
  .nav-item.active{color:var(--text);border-left-color:var(--green);background:var(--subtle)}
  .nav-icon{width:16px;height:16px;opacity:.5;flex-shrink:0}
  .nav-item.active .nav-icon{opacity:1}
  .legend{padding:.75rem 1.25rem;border-top:1px solid var(--border)}
  .legend-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:8px}
  .legend-item{display:flex;align-items:center;gap:8px;margin-bottom:6px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;color:var(--text)}
  .legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
  .legend-dot.active{background:var(--green)}
  .legend-dot.pending{background:var(--orange-mid)}
  .legend-dot.negotiating{background:var(--border-mid);border:1px solid var(--border-mid)}
  .sidebar-footer{padding:1rem 1.25rem;border-top:1px solid var(--border);font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);margin-top:auto}

  /* MAIN */
  .main{flex:1;padding:0;overflow-x:auto;min-width:0;display:flex;flex-direction:column}
  .header-bar{display:flex;justify-content:space-between;align-items:center;padding:1rem 2.5rem;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0}
  .header-bar-left h2{font-size:20px;font-weight:normal;letter-spacing:-0.01em}
  .header-bar-left p{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted);margin-top:2px}
  .header-bar-right{display:flex;align-items:center;gap:12px}
  .krw-badge{font-family:'Helvetica Neue',Arial,sans-serif;font-size:18px;font-weight:700;letter-spacing:.06em;color:var(--green);background:var(--green-bg);padding:6px 14px;border-radius:var(--radius-sm);border:1px solid var(--green-mid)}
  .header-actions{display:flex;gap:8px}
  .btn{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:7px 13px;border-radius:var(--radius-sm);cursor:pointer;border:1px solid var(--border-mid);background:var(--surface);color:var(--text);transition:all .15s}
  .btn:hover{background:var(--subtle)}
  .btn-green{background:var(--green);color:white;border-color:var(--green)}
  .btn-green:hover{background:var(--green-text)}
  .content{padding:1.5rem 2.5rem;flex:1;overflow-y:auto}

  /* STATUS TABS */
  .status-tabs{display:flex;margin-bottom:1.25rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
  .status-tab{flex:1;display:flex;align-items:center;justify-content:center;gap:7px;padding:11px 12px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px;cursor:pointer;border-right:1px solid var(--border);transition:background .15s;color:var(--muted)}
  .status-tab:last-child{border-right:none}
  .status-tab:hover{background:var(--subtle)}
  .status-tab.active-tab{background:var(--subtle);color:var(--text)}
  .tab-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .tab-dot.all{background:conic-gradient(var(--green) 0 33%,var(--orange-mid) 33% 66%,var(--border-mid) 66%)}
  .tab-dot.active{background:var(--green)}
  .tab-dot.pending{background:var(--orange-mid)}
  .tab-dot.negotiating{background:var(--border-mid);border:1px solid var(--border-mid)}
  .tab-count{font-size:10px;background:var(--border);color:var(--muted);padding:1px 6px;border-radius:20px;min-width:20px;text-align:center;font-family:'Helvetica Neue',Arial,sans-serif}
  .status-tab.active-tab .tab-count{background:var(--surface);border:1px solid var(--border)}

  /* KPI */
  .kpi-card-yearly{display:none}
  .kpi-grid.show-yearly .kpi-card-yearly{display:block}
  .yearly-toggle{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;padding:4px 10px;border-radius:var(--radius-sm);cursor:pointer;border:1px solid var(--border-mid);background:var(--surface);color:var(--muted);transition:all .15s;white-space:nowrap}
  .yearly-toggle:hover{background:var(--subtle);color:var(--text)}
  .yearly-toggle.on{background:var(--green-bg);color:var(--green-text);border-color:var(--green-mid)}
  .kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:.9rem 1rem}
  .kpi-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:6px}
  .kpi-value{font-size:20px;font-weight:normal;letter-spacing:-.01em}
  .kpi-value.green{color:var(--green)}
  .kpi-value.red{color:var(--red)}
  .kpi-sub{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);margin-top:3px}

  /* PANELS */
  .panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:1.25rem;overflow:hidden}
  .panel-header{display:flex;align-items:center;justify-content:space-between;padding:.85rem 1.25rem;border-bottom:1px solid var(--border);background:var(--subtle)}
  .panel-header-left{display:flex;align-items:center;gap:10px}
  .panel-header h3{font-size:12px;font-weight:normal;letter-spacing:.05em;text-transform:uppercase}
  .badge{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;padding:2px 7px;border-radius:20px;background:var(--border);color:var(--muted)}
  .table-wrap{overflow-x:auto}

  /* TABLE — unified columns */
  table{width:100%;border-collapse:collapse;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px}
  table colgroup col.col-status  {width:30px}
  table colgroup col.col-vertical{width:110px}
  table colgroup col.col-pub     {width:140px}
  table colgroup col.col-buyer   {width:120px}
  table colgroup col.col-money   {width:72px}
  table colgroup col.col-qty     {width:60px}
  table colgroup col.col-profit  {width:80px}
  table colgroup col.col-cycle   {width:90px}
  table colgroup col.col-notes   {width:160px}
  table colgroup col.col-del     {width:30px}

  thead th{text-align:left;padding:7px 9px;font-size:10px;font-weight:normal;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap}
  thead th.calc-col{color:var(--green);opacity:.85}
  thead th.rev-col{color:#185FA5;opacity:.85}
  table colgroup col.col-revenue{width:90px}
  thead th.notes-th{color:var(--blue);opacity:.85}
  tbody tr{border-bottom:1px solid var(--border);transition:background .12s}
  tbody tr:last-child{border-bottom:none}
  tbody tr.row-active      {background:#f4faea}
  tbody tr.row-active:hover{background:#e8f5d6}
  tbody tr.row-pending      {background:#fef8ed}
  tbody tr.row-pending:hover{background:#fdefd4}
  tbody tr.row-negotiating      {background:var(--surface)}
  tbody tr.row-negotiating:hover{background:var(--subtle)}
  tbody td{padding:0;vertical-align:middle}

  /* CELLS */
  .cell{display:block;width:100%;padding:8px 9px;outline:none;background:transparent;color:var(--text);font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px;white-space:nowrap;overflow:hidden;cursor:text}
  .cell:focus{background:#fffbe6;outline:2px solid #e0c97c;outline-offset:-2px;border-radius:3px;z-index:2;position:relative}
  .muted-val{color:var(--muted)}

  .cell-calc{display:block;width:100%;padding:8px 9px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px;white-space:nowrap;pointer-events:none;user-select:none}
  .cell-calc.profit-pos{color:var(--green);font-weight:500}
  .cell-calc.profit-neg{color:var(--red);font-weight:500}
  .cell-calc.neutral{color:var(--muted)}

  /* STATUS PILL */
  .status-pill{display:inline-flex;align-items:center;gap:5px;padding:3px 8px 3px 6px;border-radius:20px;font-size:11px;cursor:pointer;border:none;font-family:'Helvetica Neue',Arial,sans-serif;transition:all .15s;white-space:nowrap}
  .status-pill .sdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
  .status-pill.s-active     {background:var(--green-bg);color:var(--green-text)}
  .status-pill.s-active .sdot{background:var(--green)}
  .status-pill.s-pending     {background:var(--orange-bg);color:var(--orange-text)}
  .status-pill.s-pending .sdot{background:var(--orange-mid)}
  .status-pill.s-negotiating     {background:var(--subtle);color:var(--muted);border:1px solid var(--border)}
  .status-pill.s-negotiating .sdot{background:var(--border-mid)}

  /* NOTES */
  .notes-td{position:relative}
  .notes-preview{display:flex;align-items:center;gap:6px;padding:7px 9px;cursor:pointer;width:100%;min-height:34px}
  .notes-preview-text{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;flex:1}
  .notes-preview-text.has-note{color:var(--text)}
  .notes-icon{width:13px;height:13px;flex-shrink:0;opacity:.35}
  .notes-preview:hover .notes-icon{opacity:.7}
  .notes-popup{display:none;position:absolute;top:calc(100% + 4px);right:0;width:280px;background:var(--surface);border:1px solid var(--border-mid);border-radius:var(--radius);box-shadow:0 4px 20px rgba(0,0,0,.1);z-index:200;padding:10px}
  .notes-popup.open{display:block}
  .notes-popup textarea{width:100%;height:100px;border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 10px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px;color:var(--text);background:var(--subtle);resize:vertical;outline:none;line-height:1.5}
  .notes-popup textarea:focus{border-color:var(--border-mid);background:#fffbe6}
  .notes-popup-footer{display:flex;justify-content:space-between;align-items:center;margin-top:8px}
  .notes-save{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;padding:5px 12px;background:var(--green);color:white;border:none;border-radius:var(--radius-sm);cursor:pointer}
  .notes-save:hover{background:var(--green-text)}
  .notes-clear{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;padding:5px 10px;background:none;color:var(--muted);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer}
  .notes-clear:hover{color:var(--red);border-color:var(--red)}
  .notes-char{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted)}

  .del-btn{opacity:0;background:none;border:none;cursor:pointer;color:var(--red);font-size:16px;padding:2px 8px;line-height:1;transition:opacity .15s}
  tr:hover .del-btn{opacity:1}
  .add-row-btn{display:flex;align-items:center;gap:8px;padding:8px 1.25rem;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;color:var(--muted);cursor:pointer;background:none;border:none;width:100%;text-align:left;transition:all .15s;border-top:1px solid var(--border)}
  .add-row-btn:hover{background:var(--subtle);color:var(--text)}
  .empty-state{padding:1.75rem;text-align:center;font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:var(--muted)}
  .toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--text);color:white;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:10px 16px;border-radius:var(--radius-sm);opacity:0;transform:translateY(8px);transition:all .25s;pointer-events:none;z-index:9999}
  .toast.show{opacity:1;transform:translateY(0)}

  /* ── PAGE SYSTEM ── */
  .app-shell{display:flex;width:100%;height:100vh;overflow:hidden}
  .sidebar{width:210px;min-width:210px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;height:100vh;overflow-y:auto;flex-shrink:0}
  .page-area{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
  .page{display:none;flex-direction:column;flex:1;overflow:hidden}
  .page.active{display:flex}

  /* ── WEEKLY QTY KPI ── */
  .kpi-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:10px;margin-bottom:1.25rem;transition:grid-template-columns .2s}
  .kpi-grid.show-yearly{grid-template-columns:repeat(7,minmax(0,1fr))}

  /* ── HOME PAGE ── */
  .home-scroll{flex:1;overflow-y:auto;padding:1.5rem 2.5rem;display:flex;flex-direction:column;gap:1.25rem}
  .home-kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}
  .home-kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem 1.1rem}
  .home-kpi-card.gl{border-left:3px solid var(--green)}
  .home-kpi-card.bl{border-left:3px solid #185FA5}
  .home-kpi-card.ol{border-left:3px solid var(--orange-mid)}
  .home-kpi-card.pl{border-left:3px solid #7c3fb5}
  .home-kpi-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:6px}
  .home-kpi-val{font-size:26px;font-weight:normal;letter-spacing:-.02em}
  .home-kpi-val.green{color:var(--green)}
  .home-kpi-sub{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted);margin-top:4px}
  .home-row{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
  .home-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
  .home-panel-hdr{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1.1rem;border-bottom:1px solid var(--border);background:var(--subtle)}
  .home-panel-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:.06em}
  .home-panel-link{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--green);cursor:pointer;background:none;border:none;padding:0}
  .home-panel-link:hover{text-decoration:underline}
  .home-panel-body{padding:.85rem 1.1rem}
  .pipe-row{display:flex;align-items:center;gap:10px;margin-bottom:7px}
  .pipe-row:last-child{margin-bottom:0}
  .pipe-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;width:90px;flex-shrink:0}
  .pipe-bar-bg{flex:1;background:var(--subtle);border-radius:20px;height:7px;overflow:hidden}
  .pipe-bar{height:100%;border-radius:20px;transition:width .4s}
  .pipe-count{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted);width:22px;text-align:right}
  .fu-item{display:flex;align-items:flex-start;gap:10px;padding:7px 0;border-bottom:1px solid var(--border)}
  .fu-item:last-child{border-bottom:none}
  .fu-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px}
  .fu-dot.od{background:var(--red)}
  .fu-dot.td{background:var(--orange-mid)}
  .fu-name{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;font-weight:500}
  .fu-detail{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted);margin-top:1px}
  .fu-date{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;margin-left:auto;white-space:nowrap}
  .fu-date.od{color:var(--red);font-weight:500}
  .deal-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-family:'Helvetica Neue',Arial,sans-serif}
  .deal-row:last-child{border-bottom:none}
  .deal-name{font-size:12.5px}
  .deal-rev{font-size:12.5px;color:var(--green);font-weight:500}
  .deal-meta{font-size:11px;color:var(--muted)}
  .shortcuts{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:.9rem 1.1rem}
  .sc-btn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:.9rem .5rem;background:var(--subtle);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:all .15s;font-family:'Helvetica Neue',Arial,sans-serif}
  .sc-btn:hover{background:var(--green-bg);border-color:var(--green-mid)}
  .sc-icon{font-size:18px;line-height:1}
  .sc-label{font-size:11px;color:var(--muted);text-align:center;line-height:1.3}
  .sc-btn:hover .sc-label{color:var(--green-text)}
  .td-placeholder{background:var(--subtle);border:1px dashed var(--border-mid);border-radius:var(--radius-sm);padding:.75rem;text-align:center;margin-top:.5rem}
  .td-placeholder p{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted)}

  /* ── TASKS ── */
  .tasks-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
  .tasks-hdr{display:flex;align-items:center;justify-content:space-between;padding:.85rem 1.25rem;background:var(--subtle);border-bottom:1px solid var(--border);cursor:pointer;user-select:none}
  .tasks-hdr-left{display:flex;align-items:center;gap:10px}
  .tasks-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:.05em}
  .tasks-body{padding:.75rem 1.25rem 1rem}
  .task-input-row{display:flex;gap:8px;margin-bottom:.75rem;flex-wrap:wrap}
  .task-ti{flex:1;min-width:180px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;padding:7px 11px;border:1px solid var(--border-mid);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);outline:none}
  .task-ti:focus{border-color:var(--green)}
  .task-sel,.task-date{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:7px 10px;border:1px solid var(--border-mid);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);outline:none;cursor:pointer}
  .task-add{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:7px 14px;background:var(--green);color:white;border:none;border-radius:var(--radius-sm);cursor:pointer;white-space:nowrap}
  .task-add:hover{background:var(--green-text)}
  .tasks-list{display:flex;flex-direction:column;gap:5px}
  .task-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--surface);transition:all .15s}
  .task-item:hover{background:var(--subtle)}
  .task-item.done{opacity:.45}
  .task-item.done .task-lbl{text-decoration:line-through;color:var(--muted)}
  .task-cb{width:16px;height:16px;cursor:pointer;accent-color:var(--green);flex-shrink:0}
  .task-lbl{flex:1;font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:var(--text)}
  .task-due{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted);white-space:nowrap}
  .task-due.od{color:var(--red);font-weight:500}
  .task-pri{font-size:10px;padding:2px 6px;border-radius:20px;font-family:'Helvetica Neue',Arial,sans-serif}
  .task-pri.high{background:var(--red-bg);color:var(--red)}
  .task-pri.low{background:var(--subtle);color:var(--muted);border:1px solid var(--border)}
  .task-del{background:none;border:none;cursor:pointer;color:var(--muted);font-size:14px;opacity:0;padding:2px 5px;line-height:1;transition:opacity .15s}
  .task-item:hover .task-del{opacity:1}
  .task-del:hover{color:var(--red)}
  .tasks-footer{display:flex;align-items:center;justify-content:space-between;margin-top:.6rem;padding-top:.6rem;border-top:1px solid var(--border)}
  .tasks-clear{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;padding:4px 10px;background:none;border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;color:var(--muted);transition:all .15s}
  .tasks-clear:hover{color:var(--red);border-color:var(--red)}
  .tasks-empty{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:var(--muted);text-align:center;padding:1rem 0;opacity:.6}

  /* ── OUTREACH ── */
  .or-scroll{flex:1;overflow-y:auto;display:flex;flex-direction:column}
  .board{display:grid;grid-template-columns:repeat(5,minmax(190px,1fr));gap:12px;padding:1.5rem 2.5rem;overflow-x:auto}
  .board-col{background:var(--subtle);border:1px solid var(--border);border-radius:var(--radius);display:flex;flex-direction:column;min-height:250px}
  .board-col-hdr{padding:.65rem 1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--subtle);border-radius:var(--radius) var(--radius) 0 0}
  .board-col-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:.07em}
  .board-col-count{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;background:var(--border);color:var(--muted);padding:1px 6px;border-radius:20px}
  .board-col-body{padding:8px;display:flex;flex-direction:column;gap:6px;flex:1}
  .stage-cold .board-col-title{color:var(--muted)}
  .stage-contacted .board-col-title{color:#185FA5}
  .stage-responded .board-col-title{color:var(--orange)}
  .stage-intalks .board-col-title{color:#7c3fb5}
  .stage-ready .board-col-title{color:var(--green)}
  .contact-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;cursor:pointer;transition:all .15s;position:relative}
  .contact-card:hover{border-color:var(--border-mid);box-shadow:0 2px 8px rgba(0,0,0,.06)}
  .contact-card.stale{border-left:3px solid var(--orange-mid)}
  .c-name{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;font-weight:500;margin-bottom:3px;padding-right:18px}
  .c-company{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted);margin-bottom:5px}
  .c-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px}
  .c-tag{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;padding:2px 6px;border-radius:20px;background:var(--subtle);color:var(--muted);border:1px solid var(--border)}
  .c-tag.buyer{background:var(--blue-bg);color:#185FA5;border-color:#b5d4f4}
  .c-tag.seller{background:var(--green-bg);color:var(--green-text);border-color:var(--green-mid)}
  .c-tag.both{background:#f3eafe;color:#7c3fb5;border-color:#d4b8f5}
  .c-meta{display:flex;align-items:center;justify-content:space-between;margin-top:5px}
  .c-date{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted)}
  .c-date.od{color:var(--red);font-weight:500}
  .c-pot{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--green);font-weight:500}
  .c-offer{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted);margin-bottom:4px;line-height:1.4}
  .stale-badge{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;background:#FEF0DC;color:var(--orange-text);padding:1px 6px;border-radius:20px;margin-left:5px}
  .card-del{position:absolute;top:5px;right:5px;opacity:0;background:none;border:none;cursor:pointer;color:var(--red);font-size:14px;line-height:1;padding:2px 5px;transition:opacity .15s}
  .contact-card:hover .card-del{opacity:1}
  .stage-pill{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:20px;font-size:10px;font-family:'Helvetica Neue',Arial,sans-serif;white-space:nowrap}
  .stage-pill .sp-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;background:currentColor;opacity:.7}
  .stage-pill.cold{background:var(--subtle);color:var(--muted);border:1px solid var(--border)}
  .stage-pill.contacted{background:var(--blue-bg);color:#185FA5}
  .stage-pill.responded{background:var(--orange-bg);color:var(--orange-text)}
  .stage-pill.intalks{background:#f3eafe;color:#7c3fb5}
  .stage-pill.ready{background:var(--green-bg);color:var(--green-text)}
  .or-toolbar{display:flex;align-items:center;justify-content:space-between;padding:.85rem 2.5rem;border-bottom:1px solid var(--border);gap:12px;background:var(--surface);flex-shrink:0;flex-wrap:wrap}
  .or-left{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .or-search{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px;padding:6px 11px;border:1px solid var(--border-mid);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);width:200px;outline:none}
  .or-search:focus{border-color:var(--green)}
  .or-sel{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:6px 10px;border:1px solid var(--border-mid);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);outline:none;cursor:pointer}
  .view-toggle{display:flex;border:1px solid var(--border-mid);border-radius:var(--radius-sm);overflow:hidden}
  .view-btn{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;padding:6px 12px;background:var(--surface);border:none;cursor:pointer;color:var(--muted);transition:all .15s}
  .view-btn.on{background:var(--subtle);color:var(--text)}
  .or-list-wrap{padding:0 2.5rem 2rem;overflow-y:auto;flex:1}
  .or-tbl{width:100%;border-collapse:collapse;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
  .or-tbl thead th{text-align:left;padding:8px 12px;font-size:10px;font-weight:normal;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap;background:var(--subtle)}
  .or-tbl tbody tr{border-bottom:1px solid var(--border);transition:background .12s;cursor:pointer}
  .or-tbl tbody tr:hover{background:var(--subtle)}
  .or-tbl td{padding:8px 12px;vertical-align:middle}
  .fu-bar{background:#FEF0DC;border-bottom:1px solid #FAC775;padding:.55rem 2.5rem;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;color:var(--orange-text);display:none;flex-shrink:0}
  .fu-bar.show{display:block}

  /* ── MODAL ── */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:500;align-items:center;justify-content:center}
  .modal-overlay.open{display:flex}
  .modal{background:var(--surface);border-radius:var(--radius);width:560px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.18)}
  .modal-hdr{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.5rem;border-bottom:1px solid var(--border)}
  .modal-hdr h3{font-size:15px;font-weight:normal}
  .modal-x{background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted);line-height:1;padding:2px 6px}
  .modal-x:hover{color:var(--text)}
  .modal-body{padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:13px}
  .modal-footer{padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:8px}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .form-group{display:flex;flex-direction:column;gap:4px}
  .form-group.full{grid-column:1/-1}
  .form-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .form-input,.form-select,.form-textarea{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;padding:7px 10px;border:1px solid var(--border-mid);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);outline:none;transition:border .15s;width:100%}
  .form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--green)}
  .form-textarea{resize:vertical;min-height:80px;line-height:1.5}
  .promote-btn{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:7px 13px;background:var(--green-bg);color:var(--green-text);border:1px solid var(--green-mid);border-radius:var(--radius-sm);cursor:pointer;transition:all .15s}
  .promote-btn:hover{background:var(--green);color:white}

  /* ── PLACEHOLDER PAGES ── */
  .ph-center{flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px}
  .ph-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:16px;font-weight:500;color:var(--text);opacity:.4}
  .ph-sub{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:var(--muted);opacity:.5}


  /* ── DRAG AND DROP ── */
  .contact-card{cursor:grab}
  .contact-card:active{cursor:grabbing}
  .contact-card.dragging{opacity:.4;transform:scale(.98);box-shadow:0 4px 16px rgba(0,0,0,.15)}
  .board-col-body.drag-over{background:var(--green-bg);border:2px dashed var(--green-mid);border-radius:var(--radius-sm)}
  .board-col-body.drag-over-invalid{background:var(--red-bg);border:2px dashed #f09595;border-radius:var(--radius-sm)}
  .drag-handle{position:absolute;top:8px;left:8px;color:var(--border-mid);font-size:12px;cursor:grab;opacity:0;transition:opacity .15s;user-select:none;line-height:1}
  .contact-card:hover .drag-handle{opacity:1}
  .card-del{right:6px;left:auto}
  .board-col-body.drag-empty-hide .no-contacts-msg{display:none}
  .drop-indicator{height:3px;background:var(--green);border-radius:2px;margin:2px 0;display:none}
  .drop-indicator.show{display:block}
  .stage-arrow{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);padding:0 .3rem;opacity:.5}

  /* ══════════════════════════════════════════
     REVENUE / CALENDAR PAGE
  ══════════════════════════════════════════ */
  .rev-page{flex:1;display:flex;flex-direction:column;overflow:hidden}
  .rev-body{flex:1;display:flex;overflow:hidden}

  /* Sidebar filters */
  .cal-sidebar{width:220px;min-width:220px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;padding:1rem}
  .cal-sidebar-section{margin-bottom:1.25rem}
  .cal-sidebar-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:.6rem}
  .cal-filter-btn{display:flex;align-items:center;gap:8px;width:100%;background:none;border:none;padding:5px 8px;border-radius:var(--radius-sm);font-family:'Helvetica Neue',Arial,sans-serif;font-size:12.5px;color:var(--text);cursor:pointer;text-align:left;transition:background .12s}
  .cal-filter-btn:hover{background:var(--subtle)}
  .cal-filter-btn.active{background:var(--subtle);font-weight:500}
  .cal-filter-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
  .cal-filter-count{margin-left:auto;font-size:10px;background:var(--border);color:var(--muted);padding:1px 6px;border-radius:20px}

  /* Summary cards */
  .cal-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:1rem 1.5rem;border-bottom:1px solid var(--border);flex-shrink:0;background:var(--surface)}
  .cal-sum-card{background:var(--subtle);border:1px solid var(--border);border-radius:var(--radius-sm);padding:.75rem 1rem}
  .cal-sum-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:4px}
  .cal-sum-val{font-size:18px;font-weight:normal;letter-spacing:-.01em}
  .cal-sum-val.green{color:var(--green)}
  .cal-sum-val.red{color:var(--red)}
  .cal-sum-val.orange{color:var(--orange)}

  /* Calendar main */
  .cal-main{flex:1;display:flex;flex-direction:column;overflow:hidden}
  .cal-toolbar{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1.5rem;border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0}
  .cal-toolbar-left{display:flex;align-items:center;gap:8px}
  .cal-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:15px;font-weight:500;min-width:180px}
  .cal-nav-btn{background:none;border:1px solid var(--border-mid);border-radius:var(--radius-sm);padding:5px 10px;cursor:pointer;font-size:13px;color:var(--text);transition:background .12s}
  .cal-nav-btn:hover{background:var(--subtle)}
  .cal-today-btn{background:none;border:1px solid var(--border-mid);border-radius:var(--radius-sm);padding:5px 12px;cursor:pointer;font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;color:var(--text);transition:background .12s}
  .cal-today-btn:hover{background:var(--subtle)}
  .cal-view-toggle{display:flex;border:1px solid var(--border-mid);border-radius:var(--radius-sm);overflow:hidden}
  .cal-view-btn{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;padding:5px 12px;background:var(--surface);border:none;cursor:pointer;color:var(--muted);transition:all .15s}
  .cal-view-btn.on{background:var(--subtle);color:var(--text)}
  .cal-add-btn{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:6px 14px;background:var(--green);color:white;border:none;border-radius:var(--radius-sm);cursor:pointer}
  .cal-add-btn:hover{background:var(--green-text)}

  /* Month grid */
  .cal-grid-wrap{flex:1;overflow-y:auto;padding:0}
  .cal-month-grid{display:grid;grid-template-columns:repeat(7,1fr);border-left:1px solid var(--border);border-top:1px solid var(--border)}
  .cal-dow{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);padding:.5rem;text-align:center;border-right:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--surface)}
  .cal-cell{min-height:100px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:4px;position:relative;vertical-align:top;transition:background .1s;cursor:pointer}
  .cal-cell:hover{background:#fafaf8}
  .cal-cell.other-month{background:var(--subtle);opacity:.6}
  .cal-cell.today .cal-day-num{background:var(--green);color:white;border-radius:50%}
  .cal-cell.drag-over-cell{background:var(--green-bg)!important;outline:2px dashed var(--green-mid);outline-offset:-2px}
  .cal-day-num{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;width:22px;height:22px;display:flex;align-items:center;justify-content:center;margin-bottom:3px;border-radius:50%;color:var(--text)}
  .cal-event{border-radius:3px;padding:2px 5px;margin-bottom:2px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;cursor:grab;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:4px;transition:opacity .15s;user-select:none}
  .cal-event:hover{opacity:.85}
  .cal-event.dragging-ev{opacity:.3;cursor:grabbing}
  .cal-event-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;background:rgba(255,255,255,.7)}
  .cal-more{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);padding:1px 4px;cursor:pointer}
  .cal-more:hover{text-decoration:underline}

  /* Week view */
  .cal-week-wrap{flex:1;overflow-y:auto}
  .cal-week-grid{display:grid;grid-template-columns:60px repeat(7,1fr);border-left:1px solid var(--border);border-top:1px solid var(--border)}
  .cal-week-dow{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;text-align:center;padding:.5rem .25rem;border-right:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--surface)}
  .cal-week-dow span{display:block;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .cal-week-dow.today-col{color:var(--green);font-weight:500}
  .cal-time-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);padding:.25rem .4rem;border-right:1px solid var(--border);border-bottom:1px solid var(--border);text-align:right;background:var(--surface)}
  .cal-week-cell{min-height:48px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:2px;cursor:pointer;transition:background .1s}
  .cal-week-cell:hover{background:#fafaf8}
  .cal-week-cell.drag-over-cell{background:var(--green-bg)!important}

  /* Agenda view */
  .cal-agenda-wrap{flex:1;overflow-y:auto;padding:1rem 1.5rem}
  .cal-agenda-day{margin-bottom:1.25rem}
  .cal-agenda-date{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;padding:.4rem 0;border-bottom:1px solid var(--border);margin-bottom:.5rem}
  .cal-agenda-date.today-ag{color:var(--green)}
  .cal-agenda-event{display:flex;align-items:center;gap:12px;padding:.6rem .9rem;border-radius:var(--radius-sm);margin-bottom:4px;cursor:pointer;transition:all .15s;border:1px solid transparent}
  .cal-agenda-event:hover{border-color:var(--border);background:var(--subtle)}
  .cal-ag-color{width:4px;align-self:stretch;border-radius:2px;flex-shrink:0}
  .cal-ag-name{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;font-weight:500;flex:1}
  .cal-ag-meta{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;color:var(--muted)}
  .cal-ag-amount{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:var(--green);font-weight:500;white-space:nowrap}
  .cal-ag-status{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;padding:2px 7px;border-radius:20px}
  .cal-ag-status.paid{background:var(--green-bg);color:var(--green-text)}
  .cal-ag-status.unpaid{background:var(--orange-bg);color:var(--orange-text)}
  .cal-ag-status.overdue{background:var(--red-bg);color:var(--red)}

  /* Event modal */
  .ev-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:600;align-items:center;justify-content:center}
  .ev-modal-overlay.open{display:flex}
  .ev-modal{background:var(--surface);border-radius:var(--radius);width:520px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.18)}
  .ev-modal-hdr{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;border-bottom:1px solid var(--border)}
  .ev-modal-hdr h3{font-size:15px;font-weight:normal}
  .ev-modal-x{background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted);line-height:1;padding:2px 6px}
  .ev-modal-body{padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:13px}
  .ev-modal-footer{padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:8px}
  .ev-form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .ev-form-group{display:flex;flex-direction:column;gap:4px}
  .ev-form-group.full{grid-column:1/-1}
  .ev-form-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .ev-input,.ev-select,.ev-textarea{font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;padding:7px 10px;border:1px solid var(--border-mid);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);outline:none;transition:border .15s;width:100%}
  .ev-input:focus,.ev-select:focus,.ev-textarea:focus{border-color:var(--green)}
  .ev-textarea{resize:vertical;min-height:70px;line-height:1.5}
  .ev-color-row{display:flex;gap:8px;flex-wrap:wrap}
  .ev-color-swatch{width:24px;height:24px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .15s;flex-shrink:0}
  .ev-color-swatch.selected{border-color:var(--text);transform:scale(1.15)}
  .ev-delete-btn{font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;padding:7px 13px;background:none;color:var(--red);border:1px solid var(--red);border-radius:var(--radius-sm);cursor:pointer;transition:all .15s}
  .ev-delete-btn:hover{background:var(--red-bg)}
  .recurring-opts{display:flex;flex-wrap:wrap;gap:6px}
  .rec-opt{font-family:'Helvetica Neue',Arial,sans-serif;font-size:11px;padding:4px 10px;border:1px solid var(--border-mid);border-radius:20px;cursor:pointer;color:var(--muted);transition:all .15s;background:none}
  .rec-opt.on{background:var(--blue-bg);color:var(--blue);border-color:#b5d4f4}


  /* ══ REVENUE PAGE ══════════════════════════════════════ */
  .rev-scroll{flex:1;overflow-y:auto;padding:1.5rem 2.5rem;display:flex;flex-direction:column;gap:1.25rem;min-height:0}
  .rev-kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}
  .rev-kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem 1.1rem;position:relative;overflow:hidden}
  .rev-kpi.live{border-left:3px solid var(--green)}
  .rev-kpi-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:6px}
