// ── FILTER ──────────────────────────────────────
function setCalFilter(f){
  calFilter=f;
  document.querySelectorAll('.cal-filter-btn').forEach(function(b){b.classList.remove('active');});
  var btn=document.getElementById('cf-'+f.replace('v-','v-'));
  if(btn)btn.classList.add('active');
  renderCal();
}

function getFilteredEvents(){
  var today=new Date().toISOString().split('T')[0];
  return calEvents.filter(function(ev){
    if(calFilter==='all')return true;
    if(calFilter==='paid')return ev.paid==='paid';
    if(calFilter==='unpaid')return ev.paid==='unpaid';
    if(calFilter==='overdue')return ev.paid==='overdue'||(ev.paid==='unpaid'&&ev.date<today);
    if(calFilter.startsWith('v-'))return ev.vertical===calFilter.slice(2);
    return true;
  });
}

// ── SUMMARY STRIP ────────────────────────────────
function renderCalSummary(){
  var today=new Date().toISOString().split('T')[0];
  var now=new Date(); now.setHours(0,0,0,0);
  var weekEnd=new Date(now); weekEnd.setDate(weekEnd.getDate()+7);
  var monthEnd=new Date(now.getFullYear(),now.getMonth()+1,0);

  var upcoming=calEvents.filter(function(e){return e.paid!=='paid'&&e.date>=today;}).length;
  var overdue=calEvents.filter(function(e){return e.paid!=='paid'&&e.date<today;}).length;
  var weekAmt=calEvents.filter(function(e){
    var d=new Date(e.date+'T00:00:00');
    return d>=now&&d<=weekEnd;
  }).reduce(function(s,e){return s+(parseFloat(e.amount)||0);},0);
  var monthAmt=calEvents.filter(function(e){
    var d=new Date(e.date+'T00:00:00');
    return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();
  }).reduce(function(s,e){return s+(parseFloat(e.amount)||0);},0);

  var el=function(id){return document.getElementById(id);};
  if(el('cs-upcoming'))el('cs-upcoming').textContent=upcoming;
  if(el('cs-overdue'))el('cs-overdue').textContent=overdue;
  if(el('cs-week'))el('cs-week').textContent='$'+Math.round(weekAmt).toLocaleString();
  if(el('cs-month'))el('cs-month').textContent='$'+Math.round(monthAmt).toLocaleString();

  // Filter counts
  if(el('cfc-all'))el('cfc-all').textContent=calEvents.length;
  if(el('cfc-unpaid'))el('cfc-unpaid').textContent=calEvents.filter(function(e){return e.paid==='unpaid';}).length;
  if(el('cfc-overdue'))el('cfc-overdue').textContent=calEvents.filter(function(e){return e.paid==='overdue'||( e.paid==='unpaid'&&e.date<today);}).length;
  if(el('cfc-paid'))el('cfc-paid').textContent=calEvents.filter(function(e){return e.paid==='paid';}).length;
}

