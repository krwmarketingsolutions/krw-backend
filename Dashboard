function closeManualCallModal(){
  document.getElementById('manual-call-modal').style.display = 'none';
}

async function submitManualCall(){
  var buyer    = (document.getElementById('mc-buyer').value    || '').trim();
  var vertical = document.getElementById('mc-vertical').value;
  var revenue  = parseFloat(document.getElementById('mc-revenue').value || 0);
  var count    = parseInt(document.getElementById('mc-count').value || 1);

  if(!buyer)  { showToast('Buyer name is required'); return; }
  if(!revenue){ showToast('Payout amount is required'); return; }
  if(!REV_API_URL || !REV_API_KEY){ showToast('Connect your Railway server on the Revenue tab first'); return; }

  var btn = document.getElementById('mc-submit-btn');
  btn.disabled = true;
  btn.textContent = 'Adding...';

  var res    = document.getElementById('mc-result');
  var date   = document.getElementById('mc-date').value;
  var caller = document.getElementById('mc-caller').value.trim() || '+10000000000';
  var dur    = parseInt(document.getElementById('mc-duration').value || 240);
  var camp   = document.getElementById('mc-campaign').value.trim() || vertical;
  var disp   = document.getElementById('mc-disposition').value;

  // Format date as TrackDrive sends it: MM/DD/YY
  var dateParts = date.split('-');
  var tdDate = dateParts[1]+'/'+dateParts[2]+'/'+dateParts[0].slice(2);

  var successes = 0;
  var errors    = [];

  for(var i = 0; i < count; i++){
    // Vary caller ID slightly if adding multiple
    var callerId = count > 1
      ? '+1'+String(Math.floor(2000000000 + Math.random()*8000000000))
      : caller;

    var payload = {
      vertical:    vertical,
      buyer:       buyer,
      revenue:     revenue,
      caller_id:   callerId,
      call_date:   tdDate,
      campaign_id: camp,
      billable:    'true',
      duration:    dur,
      disposition: disp,
    };

    try{
      var response = await fetch(REV_API_URL + '/postback', {
        method:  'POST',
        headers: { 'Content-Type':'application/json', 'x-api-key': REV_API_KEY },
        body:    JSON.stringify(payload),
      });
      var data = await response.json();
      if(data.ok) successes++;
      else errors.push(data.error || 'Unknown error');
    } catch(err){
      errors.push(err.message);
    }
  }

  btn.disabled = false;
  btn.textContent = 'Add Call(s)';

  var resEl = document.getElementById('mc-result');
  resEl.style.display = '';
  if(successes > 0){
    resEl.style.background = 'var(--green-bg)';
    resEl.style.color = 'var(--green-text)';
    resEl.style.border = '1px solid var(--green-mid)';
    resEl.innerHTML = '✓ '+successes+' call'+(successes>1?'s':'')+' added successfully for '+buyer+' — $'+( revenue*successes).toFixed(2)+' total<br><span style="opacity:.7">Refresh the Revenue or Invoice tab to see them</span>';
    showToast(successes+' call'+(successes>1?'s':'')+' added — check Revenue & Invoice tabs');
    // Auto-refresh invoice data
    if(typeof fetchInvoiceData === 'function') setTimeout(fetchInvoiceData, 1000);
    if(typeof fetchRevenue === 'function') setTimeout(fetchRevenue, 1000);
    if(typeof fetchCalls   === 'function') setTimeout(fetchCalls,   1000);
  }
  if(errors.length){
    resEl.style.background = 'var(--red-bg)';
    resEl.style.color = 'var(--red)';
    resEl.style.border = '1px solid #f09595';
    resEl.innerHTML = '✕ Errors: '+errors.join(', ');
  }
}

