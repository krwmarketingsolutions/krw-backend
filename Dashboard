async function fetchHomeLivePayouts(){
  var payEl  = document.getElementById('hkpi-live-payouts');
  var subEl  = document.getElementById('hkpi-live-calls');
  if(!payEl) return;

  // If no Railway connection configured, show $0
  if(!REV_API_URL || !REV_API_KEY){
    payEl.textContent = '$0';
    if(subEl) subEl.textContent = 'Connect Revenue tab to activate';
    return;
  }

  try{
    var res = await fetch(REV_API_URL + '/summary', {
      headers: { 'x-api-key': REV_API_KEY }
    });
    var d = await res.json();
    if(!d.ok) throw new Error('Bad response');

    var todayTotal = parseFloat(d.today && d.today.total || 0);
    var todayCalls = parseInt(d.today && d.today.calls || 0);

    payEl.textContent = '$' + todayTotal.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});
    if(subEl) subEl.textContent = todayCalls + ' billable call' + (todayCalls!==1?'s':'') + ' today';

    // Also update the week/month on the home page if those elements exist
    var weekEl  = document.getElementById('hkpi-week');
    var monthEl = document.getElementById('hkpi-month');
    if(weekEl)  weekEl.textContent  = '$' + parseFloat(d.week  && d.week.total  || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});
    if(monthEl) monthEl.textContent = '$' + parseFloat(d.month && d.month.total || 0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});

  } catch(err){
    if(payEl) payEl.textContent = '$0';
    if(subEl) subEl.textContent = 'Could not load live data';
    console.log('Live payouts fetch error:', err.message);
  }
}

