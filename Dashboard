           (c.vertical||'')===invConfirmingData.vertical;
  });

  // Build complete line items — every call with full detail
  var lineItems = calls.map(function(call, idx){
    var dur = parseInt(call.call_duration||call.duration||0);
    var rev = parseFloat(call.payout_amount||call.revenue||0);
    return {
      line_number:  idx + 1,
      call_id:      call.id,
      date:         call.call_date || '',
      caller_id:    call.caller_id || '—',
      vertical:     call.vertical  || '',
      campaign:     call.campaign_name || call.campaign_id || '',
      duration_sec: dur,
      duration_fmt: Math.floor(dur/60)+'m '+(dur%60)+'s',
      amount:       rev,
      disposition:  call.disposition || '',
    };
  });

  // Plain text version — one call per line — for email body and QuickBooks memo
  var lineItemsText =
    '='.repeat(60) + '\n' +
    'INVOICE LINE ITEMS — ' + invConfirmingData.buyerName + '\n' +
    '='.repeat(60) + '\n' +
    '#   | Date       | Caller ID      | Duration | Amount\n' +
    '-'.repeat(60) + '\n' +
    lineItems.map(function(li){
      var num    = String(li.line_number).padStart(3,' ');
      var date   = String(li.date).padStart(10,' ');
      var caller = String(li.caller_id).padEnd(14,' ').slice(0,14);
      var dur    = String(li.duration_fmt).padStart(8,' ');
      var amt    = ('$'+li.amount.toFixed(2)).padStart(7,' ');
      return num+' | '+date+' | '+caller+' | '+dur+' | '+amt;
    }).join('\n') + '\n' +
    '-'.repeat(60) + '\n' +
    'TOTAL: $' + invConfirmingData.total.toFixed(2) +
    ' (' + lineItems.length + ' calls)\n' +
    '='.repeat(60);

  // Caller ID only list — clean list for QuickBooks description field
  var callerIdList = lineItems.map(function(li, i){
    return (i+1)+'. '+li.caller_id+' ('+li.date+') $'+li.amount.toFixed(2);
  }).join('\n');

  var dueDate = calcDueDateInv(cfg.terms||invConfirmingData.terms);
  var invoiceDate = new Date().toISOString().split('T')[0];

  var payload = {
    // ── Invoice header ──
    buyer_name:        invConfirmingData.buyerName,
    buyer_email:       cfg.email||'',
    vertical:          invConfirmingData.vertical,
    period:            invConfirmingData.period,
    call_count:        lineItems.length,
    total_amount:      invConfirmingData.total,
    payment_terms:     cfg.terms||invConfirmingData.terms,
    due_date:          dueDate,
    invoice_date:      invoiceDate,
    confirm_email:     email,
    notes:             cfg.notes||'',
    // ── All caller IDs as simple comma list (for QuickBooks memo) ──
    caller_ids_csv:    lineItems.map(function(li){ return li.caller_id; }).join(', '),
    // ── Numbered caller ID list (for email body) ──
    caller_id_list:    callerIdList,
    // ── Full formatted table (for email body) ──
    line_items_text:   lineItemsText,
    // ── Structured array (for Zapier formatter / Google Sheets etc) ──
    line_items:        lineItems,
    // ── QuickBooks description field ──
    quickbooks_description: invConfirmingData.vertical+' — '+invConfirmingData.period+' — '+lineItems.length+' billable calls',
    quickbooks_memo:   'KRW Marketing Solutions | '+invConfirmingData.buyerName+' | '+lineItems.length+' calls | Due: '+dueDate+'\n\nCallers: '+lineItems.map(function(li){ return li.caller_id; }).join(', '),
  };

  var btn = document.querySelector('#inv-confirm-modal .btn-green');
  if(btn){ btn.disabled=true; btn.textContent='Sending...'; }

  try{
    // Send through Railway server to avoid CORS issues
    // Railway forwards to Zapier server-side
    payload.zapier_webhook = webhook;
    var invoiceRes = await fetch(REV_API_URL + '/send-invoice', {
      method:  'POST',
      headers: { 'Content-Type':'application/json', 'x-api-key': REV_API_KEY },
      body:    JSON.stringify(payload),
    });
    var invoiceData = await invoiceRes.json();
    if(!invoiceData.ok) throw new Error(invoiceData.error || 'Railway forward failed');

    // Mark calls as invoiced in Railway
    if(REV_API_URL && REV_API_KEY){
      var invId = 'INV-'+Date.now();
      for(var i=0; i<lineItems.length; i++){
        try{
          await fetch(REV_API_URL+'/calls/'+lineItems[i].id, {
            method:'PATCH',
            headers:{'Content-Type':'application/json','x-api-key':REV_API_KEY},
            body: JSON.stringify({ invoice_status:'invoiced', invoice_id:invId, invoice_date:new Date().toISOString().split('T')[0] }),
          });
        }catch(e){}
      }
    }
    closeInvModal();
    showToast('Invoice sent! Check your email for confirmation.');
    setTimeout(fetchInvoiceData, 1500);
  } catch(err){
    showToast('Error: '+err.message);
  } finally {
    if(btn){ btn.disabled=false; btn.textContent='✓ Confirm & Send to Zapier'; }
  }
}

// ── Toggle billable ───────────────────────────────────────
async function toggleBillable(callId, makeBillable){
  if(!REV_API_URL||!REV_API_KEY){ showToast('Not connected to Railway'); return; }
  try{
    var res = await fetch(REV_API_URL+'/calls/'+callId+'/billable', {
      method:'PATCH',
      headers:{'Content-Type':'application/json','x-api-key':REV_API_KEY},
      body: JSON.stringify({ billable:makeBillable }),
    });
    var d = await res.json();
    if(!d.ok) throw new Error(d.error||'Failed');
    showToast(makeBillable ? 'Call restored as billable' : 'Call marked unbillable');
    fetchInvoiceData();
  }catch(err){ showToast('Error: '+err.message); }
}

// ── Search ────────────────────────────────────────────────
function filterInvoiceCalls(){
  var q       = (document.getElementById('inv-search').value||'').toLowerCase().trim();
  var results = document.getElementById('inv-search-results');
  var inner   = document.getElementById('inv-search-results-inner');
  var count   = document.getElementById('inv-search-count');
  if(!q){
    results.style.display='none';
    if(count) count.textContent='';
    return;
  }
  var matched = (invData.calls||[]).filter(function(c){
    return (c.caller_id||'').toLowerCase().includes(q)||
           (c.buyer_name||c.buyer||'').toLowerCase().includes(q)||
           (c.vertical||'').toLowerCase().includes(q)||
           (c.campaign_name||'').toLowerCase().includes(q)||
           (c.call_date||'').includes(q);
  });
  if(count) count.textContent = matched.length+' result'+(matched.length!==1?'s':'');
  results.style.display = '';
  if(!matched.length){
    inner.innerHTML = '<div style="font-family:Helvetica Neue,Arial,sans-serif;font-size:13px;color:var(--muted);text-align:center;padding:1.5rem;opacity:.6">No calls match "'+q+'"</div>';
    return;
  }
  var html = '<table class="inv-calls-tbl"><thead><tr>'+
    '<th>Date</th><th>Caller ID</th><th>Buyer</th><th>Vertical</th>'+
    '<th>Duration</th><th>Amount</th><th>Status</th><th style="text-align:center">Billable</th>'+
    '</tr></thead><tbody>';
  matched.forEach(function(call){
    var dur  = parseInt(call.call_duration||call.duration||0);
    var dStr = dur>0 ? Math.floor(dur/60)+'m '+(dur%60)+'s' : '—';
    var rev  = parseFloat(call.payout_amount||call.revenue||0);
    var inv  = call.invoice_status||'pending';
    var bill = call.billable!==false && call.billable!=='false';
    html +=
      '<tr style="'+(bill?'':'opacity:.5;background:var(--red-bg)')+'">'+
        '<td style="white-space:nowrap">'+(call.call_date||'—')+'</td>'+
        '<td style="font-weight:500">'+(call.caller_id||'—')+'</td>'+
        '<td>'+(call.buyer_name||call.buyer||'—')+'</td>'+
        '<td>'+(call.vertical||'—')+'</td>'+
        '<td style="color:var(--muted)">'+dStr+'</td>'+
        '<td style="color:var(--green);font-weight:500">$'+rev.toFixed(2)+'</td>'+
        '<td><span class="inv-status-pill '+inv+'">'+inv+'</span></td>'+
        '<td style="text-align:center">'+
          '<button class="inv-unbillable-btn'+(bill?'':' marked')+'" onclick="toggleBillable('+call.id+','+(bill?'false':'true')+')">'+
            (bill?'Mark Unbillable':'Restore')+'</button>'+
        '</td>'+
      '</tr>';
  });
  html += '</tbody></table>';
  inner.innerHTML = html;
}

