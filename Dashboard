// ── Period helpers ────────────────────────────────────────
function getInvDateRange(period){
  var now   = new Date();
  var today = now.toISOString().split('T')[0];
  var from;
  if(period==='weekly'){
    var d=new Date(now); d.setDate(now.getDate()-((now.getDay()+6)%7)); from=d.toISOString().split('T')[0];
  } else if(period==='biweekly'){
    var d=new Date(now); d.setDate(now.getDate()-13); from=d.toISOString().split('T')[0];
  } else if(period==='monthly'){
    from=today.slice(0,7)+'-01';
  } else { from=null; }
  return { from:from, to:today };
}

function fmtDateInv(str){
  if(!str || str === 'null') return '—';
  try{
    // Handle both date strings (2026-04-20) and datetime strings (2026-04-20T...)
    var clean = String(str).split('T')[0];  // take just the date part
    var parts = clean.split('-');
    if(parts.length !== 3) return str;
    var d = new Date(parseInt(parts[0]), parseInt(parts[1])-1, parseInt(parts[2]));
    return ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()]+' '+d.getDate();
  }catch(e){ return str; }
}

function calcDueDateInv(terms){
  var map={'PRE-PAY':0,'Net 7':7,'NET 7':7,'Net 10':10,'NET 10':10,'Net 14':14,'Net 15':15,'NET 15':15,'Net 30':30,'NET 30':30,'Biweekly':14,'Monthly':30};
  var days = map[terms] !== undefined ? map[terms] : 7;
  var d = new Date(); d.setDate(d.getDate()+days);
  return d.toISOString().split('T')[0];
}

