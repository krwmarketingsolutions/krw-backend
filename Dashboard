<script>

const SK='deal_dashboard_v6';
const CYCLE=['negotiating','pending','active'];

// Unified schema: vertical, publisher, buyer, buy, sell, qty, paycycle, notes, status
const DD={
  other:[
    {vertical:'SPAN FE',   publisher:'Angel',       buyer:'Michael',   buy:25,  sell:22,  qty:0, paycycle:'', notes:'', status:'active'},
    {vertical:'SPAN FE',   publisher:'Angel',       buyer:'Jacobbs',   buy:30,  sell:22,  qty:0, paycycle:'', notes:'', status:'active'},
    {vertical:'DEBT 10k+', publisher:'Brad Holmes',  buyer:'Dennis',    buy:50,  sell:70,  qty:0, paycycle:'', notes:'', status:'active'},
    {vertical:'FE IB',     publisher:'FLEX MG',      buyer:'MO',        buy:30,  sell:40,  qty:0, paycycle:'', notes:'', status:'pending'},
    {vertical:'FE English',publisher:'Jacobss',      buyer:'Caltoffic', buy:25,  sell:30,  qty:0, paycycle:'', notes:'', status:'negotiating'},
    {vertical:'SSDI CPA',  publisher:'Jacobss',      buyer:'Caltoffic', buy:200, sell:150, qty:0, paycycle:'', notes:'', status:'negotiating'},
  ],
  mva:[
    {vertical:'CPA', publisher:'LAIRD + KYLER',  buyer:'Jake (FIRM)', buy:2700, sell:3000, qty:0, paycycle:'PRE-PAY', notes:'', status:'active'},
    {vertical:'CPQ', publisher:'SAM',            buyer:'Ben Allen',   buy:1200, sell:900,  qty:0, paycycle:'PRE-PAY', notes:'', status:'active'},
    {vertical:'CPL', publisher:'Wajah Shaw',     buyer:'Holly PPC',   buy:100,  sell:150,  qty:0, paycycle:'NET 7',   notes:'Only pay when buffer passes 300', status:'pending'},
    {vertical:'CPQ', publisher:'Daniel',         buyer:'NLD',         buy:500,  sell:400,  qty:0, paycycle:'Net 10',  notes:'', status:'negotiating'},
    {vertical:'CPQ', publisher:'Flex Marketing', buyer:'NLD',         buy:500,  sell:350,  qty:0, paycycle:'Net 10',  notes:'', status:'negotiating'},
  ],
  tort:[
    {vertical:'MVA',       publisher:'LYFT',   buyer:'Lead Tree', buy:2300, sell:1700, qty:0, paycycle:'', notes:'', status:'pending'},
    {vertical:'MVA',       publisher:'Roblox', buyer:'Lead Tree', buy:1700, sell:1600, qty:0, paycycle:'', notes:'', status:'negotiating'},
    {vertical:'Mass Tort', publisher:'Depo',   buyer:'Laird',     buy:3500, sell:4000, qty:0, paycycle:'', notes:'', status:'active'},
  ]
};

let data=(()=>{try{const s=localStorage.getItem(SK);if(s)return JSON.parse(s);}catch(e){}return JSON.parse(JSON.stringify(DD));})();
let filter='all';
let openPopup=null;

function save(){try{localStorage.setItem(SK,JSON.stringify(data));}catch(e){}}
function calc(buy,sell){return (parseFloat(sell)||0)-(parseFloat(buy)||0);}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2000);
}

document.addEventListener('click',function(e){
  if(openPopup&&!openPopup.contains(e.target))closePopup(openPopup);
});

function closePopup(p){if(!p)return;p.classList.remove('open');openPopup=null;}

function openNotePopup(el,sec,idx){
  if(openPopup&&openPopup!==el.querySelector('.notes-popup'))closePopup(openPopup);
  const popup=el.querySelector('.notes-popup');
  if(popup.classList.contains('open')){closePopup(popup);return;}
  popup.querySelector('textarea').value=data[sec][idx].notes||'';
  updChar(popup);
  popup.classList.add('open');
  openPopup=popup;
  setTimeout(()=>popup.querySelector('textarea').focus(),40);
  event.stopPropagation();
}

function saveNote(btn,sec,idx){
  const popup=btn.closest('.notes-popup');
  data[sec][idx].notes=popup.querySelector('textarea').value.trim();
  save();closePopup(popup);renderAll();showToast('Note saved');
}

function clearNote(btn,sec,idx){
  const popup=btn.closest('.notes-popup');
  popup.querySelector('textarea').value='';
  data[sec][idx].notes='';
  save();closePopup(popup);renderAll();
}

function updChar(popup){
  const cc=popup.querySelector('.notes-char');
  if(cc)cc.textContent=popup.querySelector('textarea').value.length+' chars';
}

function setFilter(f){
  filter=f;
  document.querySelectorAll('.status-tab').forEach(e=>e.classList.remove('active-tab'));
  document.getElementById('tab-'+f).classList.add('active-tab');
  renderAll();
}

function show(r){return filter==='all'||r.status===filter;}

// Editable cell
function mc(val,ri,field,sec,cls=''){
  const s=String(val??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
  return `<td><span class="cell ${cls}" contenteditable="true" data-s="${sec}" data-r="${ri}" data-f="${field}" onblur="ce(this)" onkeydown="ck(event,this)">${s}</span></td>`;
}

// Auto profit cell
function profitCell(buy,sell){
  const p=calc(buy,sell);
  const cls=p>0?'profit-pos':p<0?'profit-neg':'neutral';
  const lbl=p===0?'—':(p>0?'+$'+p.toLocaleString():'-$'+Math.abs(p).toLocaleString());
  return `<td><span class="cell-calc ${cls}">${lbl}</span></td>`;
}

function revenueCell(buy,sell,qty){
  const p=calc(buy,sell);
  const q=parseFloat(qty)||0;
  const rev=p*q;
  const cls=rev>0?'profit-pos':rev<0?'profit-neg':'neutral';
  const lbl=q===0?'—':(rev>0?'$'+Math.round(rev).toLocaleString():'-$'+Math.round(Math.abs(rev)).toLocaleString());
  return `<td><span class="cell-calc ${cls}">${lbl}</span></td>`;
}

// Status pill
function pill(st,sec,idx){
  const L={active:'Active',pending:'Pending',negotiating:'Negotiating'};
  return `<td style="padding:0 4px 0 6px"><button class="status-pill s-${st}" onclick="cs('${sec}',${idx})"><span class="sdot"></span>${L[st]}</button></td>`;
}

// Notes cell
function notesCell(note,sec,idx){
  const prev=note?note.substring(0,28)+(note.length>28?'…':''):'Add note…';
  const hc=note?'has-note':'';
  return `<td class="notes-td" onclick="openNotePopup(this,'${sec}',${idx})">
    <div class="notes-preview">
      <svg class="notes-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2h10v10l-3 3H3z"/><path d="M10 12v3M10 12h3"/><path d="M5 5h6M5 8h4"/></svg>
      <span class="notes-preview-text ${hc}">${prev}</span>
    </div>
    <div class="notes-popup" onclick="event.stopPropagation()">
      <textarea placeholder="Add notes, terms, reminders…" onkeyup="updChar(this.closest('.notes-popup'))" onkeydown="if(event.key==='Escape')closePopup(this.closest('.notes-popup'))"></textarea>
      <div class="notes-popup-footer">
        <span class="notes-char">0 chars</span>
        <div style="display:flex;gap:6px">
          <button class="notes-clear" onclick="clearNote(this,'${sec}',${idx})">Clear</button>
          <button class="notes-save" onclick="saveNote(this,'${sec}',${idx})">Save</button>
        </div>
      </div>
    </div>
  </td>`;
}

// ── Keyboard navigation ─────────────────────────────────────────────
// pendingFocus stores {sec, dataRow, colIdx} to apply AFTER any re-render
let pendingFocus = null;

function getNavMap(){
  const cells = [...document.querySelectorAll('.cell[contenteditable="true"]')];
  const rows = [];
  const rowMap = {};
  cells.forEach(c => {
    const k = c.dataset.s + ':' + c.dataset.r;
    if(!rowMap[k]){ rowMap[k] = []; rows.push(k); }
    rowMap[k].push(c);
  });
  return { rows, rowMap };
}

function applyPendingFocus(){
  if(!pendingFocus) return;
  const { sec, dataRow, colIdx } = pendingFocus;
  pendingFocus = null;
  const { rows, rowMap } = getNavMap();
  const key = sec + ':' + dataRow;
  if(!rowMap[key]) return;
  const cells = rowMap[key];
  const target = cells[Math.min(colIdx, cells.length - 1)];
  if(!target) return;
  target.focus();
  try {
    const range = document.createRange();
    range.selectNodeContents(target);
    const sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
  } catch(e){}
}

function navigate(el, rowDelta, colDelta){
  const { rows, rowMap } = getNavMap();
  const currentKey = el.dataset.s + ':' + el.dataset.r;
  const currentRowIdx = rows.indexOf(currentKey);
  if(currentRowIdx === -1) return;
  const currentColIdx = rowMap[currentKey].indexOf(el);

  let tRowIdx = currentRowIdx + rowDelta;
  let tColIdx = currentColIdx + colDelta;

  // Horizontal wrap for Tab / arrow-left / arrow-right
  if(colDelta !== 0){
    const curLen = rowMap[currentKey].length;
    if(tColIdx >= curLen){
      tRowIdx = currentRowIdx + 1;
      tColIdx = 0;
    } else if(tColIdx < 0){
      tRowIdx = currentRowIdx - 1;
      tColIdx = tRowIdx >= 0 ? rowMap[rows[tRowIdx]].length - 1 : 0;
      if(tRowIdx < 0) tRowIdx = 0;
    }
  }

  // Clamp row bounds
  tRowIdx = Math.max(0, Math.min(tRowIdx, rows.length - 1));

  const targetKey = rows[tRowIdx];
  const targetCells = rowMap[targetKey];

  // Vertical navigation: stay in same column, clamp if row shorter
  if(rowDelta !== 0 && colDelta === 0){
    tColIdx = Math.min(currentColIdx, targetCells.length - 1);
  }

  // Decode key → sec and data row index
  const colonIdx = targetKey.indexOf(':');
  const targetSec = targetKey.substring(0, colonIdx);
  const targetDataRow = parseInt(targetKey.substring(colonIdx + 1));

  pendingFocus = { sec: targetSec, dataRow: targetDataRow, colIdx: tColIdx };
}

function ck(e, el){
  if(e.key === 'Tab'){
    e.preventDefault();
    navigate(el, 0, e.shiftKey ? -1 : 1);
    el.blur();
  } else if(e.key === 'Enter'){
    e.preventDefault();
    navigate(el, e.shiftKey ? -1 : 1, 0);
    el.blur();
  } else if(e.key === 'ArrowDown'){
    e.preventDefault();
    navigate(el, 1, 0);
    el.blur();
  } else if(e.key === 'ArrowUp'){
    e.preventDefault();
    navigate(el, -1, 0);
    el.blur();
  } else if(e.key === 'ArrowRight'){
    const sel = window.getSelection();
    const atEnd = !sel.focusNode || sel.focusOffset >= (sel.focusNode.textContent||'').length;
    if(atEnd){ e.preventDefault(); navigate(el, 0, 1); el.blur(); }
  } else if(e.key === 'ArrowLeft'){
    const sel = window.getSelection();
    const atStart = !sel.focusNode || sel.focusOffset === 0;
    if(atStart){ e.preventDefault(); navigate(el, 0, -1); el.blur(); }
  } else if(e.key === 'Escape'){
    pendingFocus = null;
    el.blur();
  }
}

const NF=['buy','sell','qty'];
