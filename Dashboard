function buildColorSwatches(selected){
  var row=document.getElementById('ev-color-row');
  if(!row)return;
  row.innerHTML='';
  EV_COLORS.forEach(function(col){
    var sw=document.createElement('div');
    sw.className='ev-color-swatch'+(col===selected?' selected':'');
    sw.style.background=col;
    sw.title=col;
    sw.onclick=function(){
      document.querySelectorAll('.ev-color-swatch').forEach(function(s){s.classList.remove('selected');});
      sw.classList.add('selected');
    };
    row.appendChild(sw);
  });
}

function setRecurring(btn, val){
  selectedRecurring=val;
  document.querySelectorAll('.rec-opt').forEach(function(b){b.classList.remove('on');});
  if(val)btn.classList.add('on');
  else document.querySelector('.rec-opt[data-val=""]').classList.add('on');
}

function openEvModal(id, prefillDate){
  editingEvId=id;
  var del=document.getElementById('ev-delete-btn');
  var title=document.getElementById('ev-modal-title');
  if(del)del.style.display=id!==null?'block':'none';
  if(title)title.textContent=id!==null?'Edit Event':'New Invoice Event';
  selectedRecurring='';
  document.querySelectorAll('.rec-opt').forEach(function(b){b.classList.remove('on');});
  document.querySelector('.rec-opt[data-val=""]').classList.add('on');

  if(id!==null){
    var ev=calEvents.find(function(x){return x.id===id;});
    if(!ev)return;
    document.getElementById('ev-title').value=ev.title||'';
    document.getElementById('ev-date').value=ev.date||'';
    document.getElementById('ev-followup').value=ev.followup||'';
    document.getElementById('ev-account').value=ev.account||'';
    document.getElementById('ev-vertical').value=ev.vertical||'';
    document.getElementById('ev-amount').value=ev.amount||'';
    document.getElementById('ev-terms').value=ev.terms||'';
    document.getElementById('ev-sent').value=ev.sent||'no';
    document.getElementById('ev-paid').value=ev.paid||'unpaid';
    document.getElementById('ev-notes').value=ev.notes||'';
    selectedRecurring=ev.recurring||'';
    if(ev.recurring){
      var rb=document.querySelector('.rec-opt[data-val="'+ev.recurring+'"]');
      if(rb){document.querySelector('.rec-opt[data-val=""]').classList.remove('on');rb.classList.add('on');}
    }
    buildColorSwatches(ev.color||EV_COLORS[0]);
  } else {
    ['ev-title','ev-account','ev-notes'].forEach(function(id){var el=document.getElementById(id);if(el)el.value='';});
    document.getElementById('ev-date').value=prefillDate||new Date().toISOString().split('T')[0];
    document.getElementById('ev-followup').value='';
    document.getElementById('ev-vertical').value='';
    document.getElementById('ev-amount').value='';
    document.getElementById('ev-terms').value='';
    document.getElementById('ev-sent').value='no';
    document.getElementById('ev-paid').value='unpaid';
    buildColorSwatches(EV_COLORS[0]);
  }
  document.getElementById('ev-modal').classList.add('open');
}

function closeEvModal(){
  document.getElementById('ev-modal').classList.remove('open');
  editingEvId=null;
}
document.addEventListener('click',function(e){
  var m=document.getElementById('ev-modal');
  if(m&&e.target===m)closeEvModal();
});

function saveCalEvent(){
  var title=document.getElementById('ev-title').value.trim();
  if(!title){showToast('Title is required');return;}
  var selSwatch=document.querySelector('.ev-color-swatch.selected');
  var color=selSwatch?selSwatch.style.background:EV_COLORS[0];
  var ev={
    id:editingEvId!==null?editingEvId:calNextId(),
    title:title,
    date:document.getElementById('ev-date').value,
    followup:document.getElementById('ev-followup').value,
    account:document.getElementById('ev-account').value.trim(),
    vertical:document.getElementById('ev-vertical').value,
    amount:parseFloat(document.getElementById('ev-amount').value)||0,
    terms:document.getElementById('ev-terms').value,
    sent:document.getElementById('ev-sent').value,
    paid:document.getElementById('ev-paid').value,
    recurring:selectedRecurring,
    color:color,
    notes:document.getElementById('ev-notes').value.trim()
  };
  if(editingEvId!==null){
    var i=calEvents.findIndex(function(x){return x.id===editingEvId;});
    if(i>-1)calEvents[i]=ev; else calEvents.push(ev);
  } else {
    calEvents.push(ev);
    // If recurring, generate next occurrences
    if(ev.recurring&&ev.date){
      var intervals={weekly:7,biweekly:14,net7:7,net10:10,net15:15,net30:30,monthly:30};
      var gap=intervals[ev.recurring];
      if(gap){
        for(var r=1;r<=3;r++){
          var nd=new Date(ev.date+'T00:00:00');
          nd.setDate(nd.getDate()+gap*r);
          var rec=JSON.parse(JSON.stringify(ev));
          rec.id=calNextId()+r;
          rec.date=nd.toISOString().split('T')[0];
          calEvents.push(rec);
        }
      }
    }
  }
  calSave();closeEvModal();renderCal();
  showToast(editingEvId!==null?'Event updated':'Event saved');
}

function deleteCalEvent(){
  if(!confirm('Delete this event?'))return;
  calEvents=calEvents.filter(function(x){return x.id!==editingEvId;});
  calSave();closeEvModal();renderCal();showToast('Event deleted');
}

