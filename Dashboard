      document.getElementById('rv-top-vert-rev').textContent = '';
    }

    // Today by vertical bars
    renderVerticalBars('rv-by-vert', d.today.by_vertical || []);

    // All-time by vertical
    renderVerticalBars('rv-alltime-vert', d.by_vertical || []);

    setRevStatus('connected', 'Updated ' + now);
