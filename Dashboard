  document.getElementById('kpi-deals').textContent=active.length;
  document.getElementById('kpi-deals-sub').textContent=
    `${data.other.filter(r=>r.status==='active').length} ins · `+
    `${data.mva.filter(r=>r.status==='active').length} mva · `+
    `${data.tort.filter(r=>r.status==='active').length} tort`;

  // Total quantity across active deals
  const totalQty = active.reduce((s,r)=>s+(parseFloat(r.qty)||0), 0);
  document.getElementById('kpi-qty').textContent = Math.round(totalQty).toLocaleString();
  document.getElementById('kpi-qty-weekly').textContent = Math.round(totalQty * 5).toLocaleString();
  document.getElementById('kpi-qty-sub').textContent =
    `${data.other.filter(r=>r.status==='active').reduce((s,r)=>s+(parseFloat(r.qty)||0),0)} ins · `+
    `${data.mva.filter(r=>r.status==='active').reduce((s,r)=>s+(parseFloat(r.qty)||0),0)} mva · `+
    `${data.tort.filter(r=>r.status==='active').reduce((s,r)=>s+(parseFloat(r.qty)||0),0)} tort`;

  // Revenue
  const daily=active.reduce((s,r)=>s+calc(r.buy,r.sell)*(parseFloat(r.qty)||0),0);
  const fmt=v=>'$'+Math.round(v).toLocaleString();
  document.getElementById('kpi-daily').textContent=fmt(daily);
  document.getElementById('kpi-weekly').textContent=fmt(daily*5);
  document.getElementById('kpi-monthly').textContent=fmt(daily*5*4);
  document.getElementById('kpi-yearly').textContent=fmt(daily*5*4*12);
  ['kpi-daily','kpi-weekly','kpi-monthly','kpi-yearly'].forEach(id=>{
    document.getElementById(id).className='kpi-value '+(daily<0?'red':'green');
