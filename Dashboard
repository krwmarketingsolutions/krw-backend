  else if(calView==='week'){calCurrent.setDate(calCurrent.getDate()+dir*7);}
  else{calCurrent.setMonth(calCurrent.getMonth()+dir);}
  renderCal();
}

function calToday(){calCurrent=new Date();renderCal();}

function renderCal(){
  renderCalSummary();
  if(calView==='month')renderMonth();
  else if(calView==='week')renderWeek();
  else renderAgenda();
}

// ── MONTH VIEW ───────────────────────────────────
function renderMonth(){
  var MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
  var titleEl=document.getElementById('cal-title');
  if(titleEl)titleEl.textContent=MONTHS[calCurrent.getMonth()]+' '+calCurrent.getFullYear();

  var grid=document.getElementById('cal-month-body');
  if(!grid)return;
  grid.innerHTML='';

  var today=new Date(); today.setHours(0,0,0,0);
  var year=calCurrent.getFullYear(), month=calCurrent.getMonth();
  var firstDay=new Date(year,month,1).getDay();
  var daysInMonth=new Date(year,month+1,0).getDate();
  var daysInPrev=new Date(year,month,0).getDate();
  var filtered=getFilteredEvents();

  var totalCells=Math.ceil((firstDay+daysInMonth)/7)*7;
  for(var i=0;i<totalCells;i++){
    var cell=document.createElement('div');
    cell.className='cal-cell';
    var dayNum, isOther=false, dateStr;
    if(i<firstDay){
      dayNum=daysInPrev-firstDay+i+1;
      isOther=true;
      var pm=month===0?11:month-1;
      var py=month===0?year-1:year;
      dateStr=py+'-'+String(pm+1).padStart(2,'0')+'-'+String(dayNum).padStart(2,'0');
    } else if(i>=firstDay+daysInMonth){
      dayNum=i-firstDay-daysInMonth+1;
      isOther=true;
      var nm=month===11?0:month+1;
      var ny=month===11?year+1:year;
      dateStr=ny+'-'+String(nm+1).padStart(2,'0')+'-'+String(dayNum).padStart(2,'0');
    } else {
      dayNum=i-firstDay+1;
      dateStr=year+'-'+String(month+1).padStart(2,'0')+'-'+String(dayNum).padStart(2,'0');
    }
    if(isOther)cell.classList.add('other-month');
    var cellDate=new Date(dateStr+'T00:00:00');
    if(cellDate.getTime()===today.getTime())cell.classList.add('today');
    var dn=document.createElement('div');
    dn.className='cal-day-num';
    dn.textContent=dayNum;
    cell.appendChild(dn);

    // Events for this day
    var dayEvs=filtered.filter(function(e){return e.date===dateStr;});
    var maxShow=3;
    dayEvs.slice(0,maxShow).forEach(function(ev){
      var evEl=makeEventChip(ev,dateStr);
      cell.appendChild(evEl);
    });
    if(dayEvs.length>maxShow){
      var more=document.createElement('div');
      more.className='cal-more';
      more.textContent='+'+(dayEvs.length-maxShow)+' more';
      more.onclick=function(e){e.stopPropagation();setCalView('agenda');};
      cell.appendChild(more);
    }

    // Click to add
    cell.addEventListener('click',function(ds){return function(){openEvModal(null,ds);};}(dateStr));

    // Drop zone
    cell.setAttribute('data-date',dateStr);
    cell.ondragover=function(e){e.preventDefault();this.classList.add('drag-over-cell');};
    cell.ondragleave=function(){this.classList.remove('drag-over-cell');};
    cell.ondrop=function(e){
      e.preventDefault();
      this.classList.remove('drag-over-cell');
      var targetDate=this.getAttribute('data-date');
      if(dragEvId!==null){
        var ev=calEvents.find(function(x){return x.id===dragEvId;});
        if(ev){ev.date=targetDate;calSave();renderCal();showToast(ev.title+' moved to '+targetDate);}
      }
      dragEvId=null;
    };

    grid.appendChild(cell);
  }
}

function makeEventChip(ev, dateStr){
  var today=new Date().toISOString().split('T')[0];
  var isOverdue=(ev.paid==='overdue')||(ev.paid==='unpaid'&&ev.date<today);
  var color=ev.color||VERT_COLORS[ev.vertical]||'#888780';
  var chip=document.createElement('div');
  chip.className='cal-event';
  chip.style.background=color;
  chip.style.color='white';
  chip.setAttribute('draggable','true');
  chip.setAttribute('data-id',ev.id);
  var statusDot=ev.paid==='paid'?'✓':isOverdue?'!':'';
  chip.innerHTML='<span class="cal-event-dot"></span>'+( statusDot?'<span style="font-size:9px;font-weight:700">'+statusDot+'</span> ':'')+ev.title+(ev.amount?'  $'+Number(ev.amount).toLocaleString():'');
  chip.ondragstart=function(e){
    dragEvId=ev.id;
    chip.classList.add('dragging-ev');
    e.dataTransfer.effectAllowed='move';
    e.stopPropagation();
  };
  chip.ondragend=function(){chip.classList.remove('dragging-ev');dragEvId=null;};
  chip.addEventListener('click',function(e){e.stopPropagation();openEvModal(ev.id,null);});
  return chip;
}

// ── WEEK VIEW ────────────────────────────────────
function renderWeek(){
  var DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var MONTHS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var today=new Date(); today.setHours(0,0,0,0);
  var startOfWeek=new Date(calCurrent);
  startOfWeek.setDate(calCurrent.getDate()-calCurrent.getDay());

  var titleEl=document.getElementById('cal-title');
  var endOfWeek=new Date(startOfWeek); endOfWeek.setDate(endOfWeek.getDate()+6);
  if(titleEl)titleEl.textContent=MONTHS[startOfWeek.getMonth()]+' '+startOfWeek.getDate()+' – '+MONTHS[endOfWeek.getMonth()]+' '+endOfWeek.getDate()+', '+endOfWeek.getFullYear();

  var hdr=document.getElementById('cal-week-header');
  var body=document.getElementById('cal-week-body');
  if(!hdr||!body)return;
  hdr.innerHTML='<div class="cal-time-label"></div>';
  body.innerHTML='';

  var filtered=getFilteredEvents();
  var weekDates=[];
  for(var i=0;i<7;i++){
    var d=new Date(startOfWeek); d.setDate(d.getDate()+i);
    weekDates.push(d);
    var dStr=d.toISOString().split('T')[0];
    var isToday=d.getTime()===today.getTime();
    var dh=document.createElement('div');
    dh.className='cal-week-dow'+(isToday?' today-col':'');
    dh.innerHTML='<span>'+DAYS[d.getDay()]+'</span>'+d.getDate();
    hdr.appendChild(dh);
  }

  // Create rows for each day's events
  var maxRows=1;
  var dayEvs=weekDates.map(function(d){return filtered.filter(function(e){return e.date===d.toISOString().split('T')[0];});});
  dayEvs.forEach(function(evs){if(evs.length>maxRows)maxRows=evs.length;});
  for(var r=0;r<Math.max(maxRows,3);r++){
    var timeLabel=document.createElement('div');
    timeLabel.className='cal-time-label';
    timeLabel.textContent='';
    body.appendChild(timeLabel);
    weekDates.forEach(function(d,di){
      var cell=document.createElement('div');
      cell.className='cal-week-cell';
      var dStr=d.toISOString().split('T')[0];
      var evs=dayEvs[di];
      if(evs[r]){
        var chip=makeEventChip(evs[r],dStr);
        chip.style.fontSize='10px';
        cell.appendChild(chip);
      }
      cell.setAttribute('data-date',dStr);
      cell.ondragover=function(e){e.preventDefault();this.classList.add('drag-over-cell');};
      cell.ondragleave=function(){this.classList.remove('drag-over-cell');};
      cell.ondrop=function(e){
        e.preventDefault(); this.classList.remove('drag-over-cell');
        var targetDate=this.getAttribute('data-date');
        if(dragEvId!==null){
          var ev=calEvents.find(function(x){return x.id===dragEvId;});
          if(ev){ev.date=targetDate;calSave();renderCal();showToast(ev.title+' moved');}
        }
        dragEvId=null;
      };
      cell.addEventListener('click',function(ds){return function(){openEvModal(null,ds);};}(dStr));
      body.appendChild(cell);
    });
  }
}

// ── AGENDA VIEW ──────────────────────────────────
function renderAgenda(){
  var MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
  var titleEl=document.getElementById('cal-title');
  if(titleEl)titleEl.textContent=MONTHS[calCurrent.getMonth()]+' '+calCurrent.getFullYear();

  var wrap=document.getElementById('cal-agenda-view');
  if(!wrap)return;
  wrap.innerHTML='';

  var today=new Date().toISOString().split('T')[0];
  var year=calCurrent.getFullYear(), month=calCurrent.getMonth();
  var daysInMonth=new Date(year,month+1,0).getDate();
  var filtered=getFilteredEvents();
  var hasAny=false;

  for(var d=1;d<=daysInMonth;d++){
    var dateStr=year+'-'+String(month+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    var dayEvs=filtered.filter(function(e){return e.date===dateStr;});
    if(!dayEvs.length)continue;
    hasAny=true;
    var section=document.createElement('div');
    section.className='cal-agenda-day';
    var dateLabel=document.createElement('div');
    dateLabel.className='cal-agenda-date'+(dateStr===today?' today-ag':'');
    var dt=new Date(dateStr+'T00:00:00');
    dateLabel.textContent=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][dt.getDay()]+', '+['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][dt.getMonth()]+' '+d;
    section.appendChild(dateLabel);
    dayEvs.forEach(function(ev){
      var isOd=(ev.paid==='overdue')||(ev.paid==='unpaid'&&ev.date<today);
      var color=ev.color||VERT_COLORS[ev.vertical]||'#888780';
      var row=document.createElement('div');
      row.className='cal-agenda-event';
      var status=ev.paid==='paid'?'paid':isOd?'overdue':'unpaid';
      row.innerHTML=
        '<div class="cal-ag-color" style="background:'+color+'"></div>'+
        '<div style="flex:1">'+
          '<div class="cal-ag-name">'+ev.title+'</div>'+
          '<div class="cal-ag-meta">'+(ev.account?ev.account+' · ':'')+( ev.vertical?ev.vertical+' · ':'')+( ev.terms?ev.terms:'')+'</div>'+
        '</div>'+
        (ev.amount?'<div class="cal-ag-amount">$'+Number(ev.amount).toLocaleString()+'</div>':'')+
        '<span class="cal-ag-status '+status+'">'+status.charAt(0).toUpperCase()+status.slice(1)+'</span>';
      row.addEventListener('click',function(eid){return function(){openEvModal(eid,null);};}(ev.id));
      section.appendChild(row);
    });
    wrap.appendChild(section);
  }
  if(!hasAny){wrap.innerHTML='<div style="font-family:Helvetica Neue,Arial,sans-serif;font-size:13px;color:var(--muted);text-align:center;padding:2rem;opacity:.6">No events this month</div>';}
}

