// ── Fetch invoice data ────────────────────────────────────
async function fetchInvoiceData(){
  var list = document.getElementById('inv-buyer-list');
  if(!REV_API_URL || !REV_API_KEY){
    if(list) list.innerHTML = '<div style="font-family:Helvetica Neue,Arial,sans-serif;font-size:13px;color:var(--muted);text-align:center;padding:3rem;opacity:.6">Connect your Railway server on the Revenue tab first</div>';
    return;
  }
  var range = getInvDateRange(invPeriod);
  var rangeEl = document.getElementById('inv-date-range');
  if(rangeEl) rangeEl.textContent = range.from ? fmtDateInv(range.from)+' – '+fmtDateInv(range.to) : 'All time';

  var url = REV_API_URL+'/invoice-summary';
  if(range.from) url += '?from='+range.from+'&to='+range.to;

  try{
    var res = await fetch(url, { headers:{'x-api-key':REV_API_KEY} });
    var d   = await res.json();
    if(!d.ok) throw new Error(d.error||'Bad response');
    invData = d;
    renderInvoicePage(d);
    renderBuyerConfigSidebar();
  } catch(err){
    if(list) list.innerHTML = '<div style="font-family:Helvetica Neue,Arial,sans-serif;font-size:13px;color:var(--muted);text-align:center;padding:3rem;opacity:.6">Error: '+err.message+'</div>';
  }
}

