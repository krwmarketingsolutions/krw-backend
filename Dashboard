function orSave(){try{localStorage.setItem(OR_KEY,JSON.stringify(orData));}catch(e){}}
function orNextId(){return orData.length?Math.max.apply(null,orData.map(function(c){return c.id;}))+1:1;}
function daysSince(d){if(!d)return null;return Math.floor((new Date()-new Date(d))/86400000);}
function isStale(c){var d=daysSince(c.lastContact);return d!==null&&d>=7;}
function isOverdue(c){if(!c.followup)return false;return new Date(c.followup)<new Date();}

function setOrView(v){
  orView=v;
  document.getElementById('or-board').style.display=v==='board'?'':'none';
  document.getElementById('or-list').style.display=v==='list'?'':'none';
  document.getElementById('vbtn-board').classList.toggle('on',v==='board');
  document.getElementById('vbtn-list').classList.toggle('on',v==='list');
}

function getFiltered(){
  var q=(document.getElementById('or-search').value||'').toLowerCase();
  var role=document.getElementById('or-role').value||'';
  var stage=document.getElementById('or-stage').value||'';
  return orData.filter(function(c){
    if(role&&c.role!==role)return false;
    if(stage&&c.stage!==stage)return false;
    if(q&&!(c.name.toLowerCase().includes(q)||(c.company||'').toLowerCase().includes(q)||(c.vertical||'').toLowerCase().includes(q)))return false;
    return true;
  });
}

function roleBadge(r){var m={buyer:'buyer',seller:'seller',both:'both'};var l={buyer:'Buyer',seller:'Seller',both:'Buyer + Seller'};return '<span class="c-tag '+m[r]+'">'+l[r]+'</span>';}
function stagePill(s){return '<span class="stage-pill '+s+'"><span class="sp-dot"></span>'+STAGE_LABELS[s]+'</span>';}

function renderOutreach(){
  var contacts=getFiltered();
  var today=new Date().toISOString().split('T')[0];
  var staleN=orData.filter(isStale).length;
  var odN=orData.filter(isOverdue).length;
  var fb=document.getElementById('fu-bar');
  if(fb){
    var msgs=[];
    if(odN)msgs.push('⚠ '+odN+' overdue follow-up'+(odN>1?'s':''));
    if(staleN)msgs.push(staleN+' contact'+(staleN>1?'s':'')+' not reached in 7+ days');
    fb.textContent=msgs.join('  ·  ');
    fb.className='fu-bar'+(msgs.length?' show':'');
  }
  if(orView==='board')renderBoard(contacts);
  else renderList(contacts);
}

var dragId = null;

function renderBoard(contacts){
  STAGES.forEach(function(stage){
    var col=document.getElementById('bcol-'+stage);
    var cnt=document.getElementById('cnt-'+stage);
    if(!col)return;
    var sc=contacts.filter(function(c){return c.stage===stage;});
    if(cnt)cnt.textContent=sc.length;
    col.innerHTML='';

    // Make column a drop zone
    col.setAttribute('data-stage', stage);
    col.ondragover  = function(e){ e.preventDefault(); col.classList.add('drag-over'); };
    col.ondragleave = function(e){ if(!col.contains(e.relatedTarget)) col.classList.remove('drag-over'); };
    col.ondrop      = function(e){
      e.preventDefault();
      col.classList.remove('drag-over');
      var targetStage = col.getAttribute('data-stage');
      if(dragId !== null && targetStage){
        var contact = orData.find(function(x){return x.id===dragId;});
        if(contact && contact.stage !== targetStage){
          contact.stage = targetStage;
          orSave();
          renderOutreach();
          showToast(contact.name + ' → ' + STAGE_LABELS[targetStage]);
        }
      }
      dragId = null;
    };

    if(!sc.length){
      col.innerHTML='<div class="no-contacts-msg" style="font-family:Helvetica Neue,Arial,sans-serif;font-size:12px;color:var(--muted);text-align:center;padding:1.5rem 1rem;opacity:.5">Drop here</div>';
      return;
    }

    sc.forEach(function(c){
      var stale=isStale(c),od=isOverdue(c),da=daysSince(c.lastContact);
      var card=document.createElement('div');
      card.className='contact-card'+(stale?' stale':'');
      card.setAttribute('draggable','true');
      card.setAttribute('data-id', c.id);
      card.innerHTML=
        '<span class="drag-handle" title="Drag to move">⠿</span>'+
        '<button class="card-del" onclick="event.stopPropagation();deleteContact('+c.id+')">×</button>'+
        '<div class="c-name">'+c.name+(stale?'<span class="stale-badge">'+da+'d</span>':'')+'</div>'+
        (c.company?'<div class="c-company">'+c.company+'</div>':'')+
        '<div class="c-tags">'+roleBadge(c.role)+(c.vertical?'<span class="c-tag">'+c.vertical.split(',')[0].trim()+'</span>':'')+'<span class="c-tag">'+c.source+'</span></div>'+
        (c.offer?'<div class="c-offer">'+c.offer.substring(0,70)+(c.offer.length>70?'...':'')+'</div>':'')+
        '<div class="c-meta"><span class="c-date'+(od?' od':'')+'">'+( c.followup?'Follow-up: '+c.followup:(c.lastContact?'Last: '+c.lastContact:'No contact'))+'</span>'+(c.potential>0?'<span class="c-pot">~$'+Number(c.potential).toLocaleString()+'</span>':'')+'</div>';

      // Drag events
      card.ondragstart = function(e){
        dragId = c.id;
        card.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', c.id);
      };
      card.ondragend = function(){
        card.classList.remove('dragging');
        document.querySelectorAll('.board-col-body').forEach(function(b){
          b.classList.remove('drag-over','drag-over-invalid');
        });
        dragId = null;
      };

      // Click to edit (only if not dragging)
      card.addEventListener('click', function(e){
        if(!e.target.classList.contains('card-del') && !e.target.classList.contains('drag-handle')){
          openContactModal(c.id);
        }
      });

      col.appendChild(card);
    });
  });
}

function renderList(contacts){
  var tb=document.getElementById('or-list-body');
  if(!tb)return;
  tb.innerHTML='';
  if(!contacts.length){tb.innerHTML='<tr><td colspan="10" style="text-align:center;padding:2rem;color:var(--muted);font-family:Helvetica Neue,Arial,sans-serif">No contacts match filters</td></tr>';return;}
  contacts.forEach(function(c){
    var stale=isStale(c),od=isOverdue(c);
    var tr=document.createElement('tr');
    tr.innerHTML='<td style="font-weight:500">'+c.name+(stale?'<span class="stale-badge">stale</span>':'')+'</td>'+
      '<td style="color:var(--muted)">'+(c.company||'—')+'</td>'+
      '<td>'+roleBadge(c.role)+'</td>'+
      '<td style="color:var(--muted)">'+(c.vertical||'—')+'</td>'+
      '<td>'+stagePill(c.stage)+'</td>'+
      '<td style="color:var(--muted)">'+(c.source||'—')+'</td>'+
      '<td style="color:var(--muted)">'+(c.lastContact||'—')+'</td>'+
      '<td style="color:'+(od?'var(--red)':'var(--muted)')+(od?';font-weight:500':'')+'">'+(c.followup||'—')+'</td>'+
      '<td style="color:var(--green)">'+(c.potential>0?'~$'+Number(c.potential).toLocaleString():'—')+'</td>'+
      '<td><button class="del-btn" style="opacity:1" onclick="event.stopPropagation();deleteContact('+c.id+')">×</button></td>';
    tr.addEventListener('click',function(e){if(e.target.tagName!=='BUTTON')openContactModal(c.id);});
    tb.appendChild(tr);
  });
}

function openContactModal(id){
  editingId=id;
  document.getElementById('modal-title').textContent=id===null?'Add Contact':'Edit Contact';
  document.getElementById('promote-btn').style.display=id===null?'none':'block';
  var c=id!==null?orData.find(function(x){return x.id===id;}):null;
  document.getElementById('f-name').value=c?c.name:'';
  document.getElementById('f-company').value=c?c.company:'';
  document.getElementById('f-role').value=c?c.role:'buyer';
  document.getElementById('f-vertical').value=c?c.vertical:'';
  document.getElementById('f-stage').value=c?c.stage:'cold';
  document.getElementById('f-source').value=c?c.source:'LinkedIn';
  document.getElementById('f-lc').value=c?c.lastContact:new Date().toISOString().split('T')[0];
  document.getElementById('f-fu').value=c?c.followup:'';
  document.getElementById('f-contact').value=c?c.contact:'';
  document.getElementById('f-potential').value=c?c.potential:'';
  document.getElementById('f-offer').value=c?c.offer:'';
  document.getElementById('f-notes').value=c?c.notes:'';
  document.getElementById('contact-modal').classList.add('open');
}

function closeContactModal(){
  document.getElementById('contact-modal').classList.remove('open');
  editingId=null;
}

document.addEventListener('click',function(e){
  var m=document.getElementById('contact-modal');
  if(m&&e.target===m)closeContactModal();
});

function saveContact(){
  var name=document.getElementById('f-name').value.trim();
  if(!name){showToast('Name is required');return;}
  var c={
    id:editingId!==null?editingId:orNextId(),
    name:name,
    company:document.getElementById('f-company').value.trim(),
    role:document.getElementById('f-role').value,
    vertical:document.getElementById('f-vertical').value.trim(),
    stage:document.getElementById('f-stage').value,
    source:document.getElementById('f-source').value,
    lastContact:document.getElementById('f-lc').value,
    followup:document.getElementById('f-fu').value,
    contact:document.getElementById('f-contact').value.trim(),
    potential:parseFloat(document.getElementById('f-potential').value)||0,
    offer:document.getElementById('f-offer').value.trim(),
    notes:document.getElementById('f-notes').value.trim()
  };
  if(editingId!==null){var i=orData.findIndex(function(x){return x.id===editingId;});if(i>-1)orData[i]=c;else orData.push(c);}
  else orData.push(c);
  orSave();closeContactModal();renderOutreach();
  showToast(editingId!==null?'Contact updated':'Contact added');
}

function deleteContact(id){
  if(!confirm('Delete this contact?'))return;
  orData=orData.filter(function(c){return c.id!==id;});
  orSave();renderOutreach();showToast('Contact deleted');
}

function promoteContact(){
  var c=orData.find(function(x){return x.id===editingId;});
  if(!c)return;
  var v=(c.vertical||'').toLowerCase();
  var sec='other';
  if(v.includes('tort')||v.includes('lyft')||v.includes('roblox')||v.includes('depo'))sec='tort';
  else if(v.includes('mva')||v.includes('cpa')||v.includes('cpq')||v.includes('cpl'))sec='mva';
  data[sec].push({vertical:c.vertical||'',publisher:c.name,buyer:'',buy:0,sell:0,qty:0,paycycle:'',notes:(c.offer+(c.notes?'\n'+c.notes:'')).trim(),status:'negotiating'});
  save();
  orData=orData.filter(function(x){return x.id!==editingId;});
  orSave();closeContactModal();renderAll();renderOutreach();
  showToast(c.name+' promoted to '+(sec==='tort'?'Mass Tort':sec==='mva'?'MVA':'Insurance'));
}

