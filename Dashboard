    var d = await res.json();
    if(!d.ok) throw new Error('Bad response');

    var fmt = function(v){ return '$' + Math.round(v||0).toLocaleString(); };
    var now = new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});

