<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DEPO FORM → Upload to GitHub repo "depo" → enables krwmarketingsolutions.github.io/depo</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Helvetica Neue',Arial,sans-serif;background:#f4f4f4;min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:1.5rem 1rem}
  .card{background:white;border-radius:8px;box-shadow:0 2px 16px rgba(0,0,0,.1);width:100%;max-width:540px;overflow:hidden}
  .card-hdr{background:#1a1a2e;color:white;padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:12px}
  .card-hdr h1{font-size:16px;font-weight:600;margin-bottom:2px}
  .card-hdr p{font-size:12px;opacity:.6}
  .instructions-btn{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);color:white;border-radius:5px;padding:6px 12px;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;transition:background .15s}
  .instructions-btn:hover{background:rgba(255,255,255,.22)}
  .card-body{padding:1.5rem}
  .form-group{margin-bottom:14px}
  .form-group label{display:flex;align-items:center;gap:3px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#555;margin-bottom:5px}
  .req{color:#e53e3e;font-size:14px;line-height:1;font-weight:700}
  .form-group input,.form-group select,.form-group textarea{width:100%;padding:9px 12px;border:1px solid #ddd;border-radius:5px;font-size:13px;font-family:inherit;outline:none;transition:border .15s;background:#fafafa;color:#1a1a2e}
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:#2d6a4f;background:white;box-shadow:0 0 0 3px rgba(45,106,79,.08)}
  .form-group input.invalid,.form-group select.invalid{border-color:#e53e3e !important;background:#fff5f5 !important}
  .field-error{font-size:11px;color:#e53e3e;margin-top:3px;display:none}
  .field-error.show{display:block}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .form-row-3{display:grid;grid-template-columns:2fr 1fr 1fr;gap:12px}
  .section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#999;margin:20px 0 10px;padding-bottom:5px;border-bottom:1px solid #eee;display:flex;align-items:center;gap:6px}
  .optional-badge{font-size:9px;background:#f0f0f0;color:#aaa;padding:1px 6px;border-radius:10px;font-weight:normal;text-transform:none;letter-spacing:0}
  .submit-btn{width:100%;padding:13px;background:#2d6a4f;color:white;border:none;border-radius:5px;font-size:14px;font-weight:600;cursor:pointer;margin-top:8px;transition:background .15s}
  .submit-btn:hover:not(:disabled){background:#1b4332}
  .submit-btn:disabled{background:#aaa;cursor:not-allowed}
  .result{margin-top:12px;padding:12px 14px;border-radius:5px;font-size:13px;display:none}
  .result.success{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7}
  .result.error{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5}
  .note{font-size:11px;color:#aaa;margin-top:4px}
  /* Modal */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:100;align-items:center;justify-content:center;padding:1rem}
  .modal-overlay.open{display:flex}
  .modal{background:white;border-radius:8px;width:100%;max-width:580px;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.25)}
  .modal-hdr{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;background:#1a1a2e;color:white;border-radius:8px 8px 0 0;position:sticky;top:0;z-index:1}
  .modal-hdr h2{font-size:14px;font-weight:600}
  .modal-x{background:none;border:none;color:white;font-size:22px;cursor:pointer;line-height:1;padding:2px 6px;opacity:.7}
  .modal-x:hover{opacity:1}
  .modal-body{padding:1.25rem}
  .instructions-box{background:#0f172a;color:#e2e8f0;border-radius:6px;padding:1rem 1.1rem;font-family:'Courier New',monospace;font-size:11.5px;line-height:1.8;white-space:pre;overflow-x:auto;margin-bottom:12px;max-height:60vh;overflow-y:auto}
  .copy-btn{width:100%;padding:11px;background:#2d6a4f;color:white;border:none;border-radius:5px;font-size:13px;font-weight:600;cursor:pointer;transition:background .15s}
  .copy-btn:hover{background:#1b4332}
  .copy-btn.copied{background:#065f46}
</style>
</head>
<body>

<div class="card">
  <div class="card-hdr">
    <div>
      <h1>DEPO Lead Submission</h1>
      <p>Submit lead data via this form</p>
    </div>
    <button class="instructions-btn" onclick="showInstructions()">📋 Posting Instructions</button>
  </div>
  <div class="card-body">
    <form id="lead-form" autocomplete="off" novalidate>

      <div class="section-label">Claimant Information</div>

      <div class="form-row">
        <div class="form-group">
          <label>First Name <span class="req">*</span></label>
          <input type="text" name="firstName" placeholder="Jane"/>
          <div class="field-error" id="err-firstName">First name is required</div>
        </div>
        <div class="form-group">
          <label>Last Name <span class="req">*</span></label>
          <input type="text" name="lastName" placeholder="Smith"/>
          <div class="field-error" id="err-lastName">Last name is required</div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Email <span class="req">*</span></label>
          <input type="email" name="email" placeholder="jane@gmail.com"/>
          <div class="field-error" id="err-email">Valid email is required</div>
        </div>
        <div class="form-group">
          <label>Cell Phone <span class="req">*</span></label>
          <input type="tel" name="phone" placeholder="3105550123" maxlength="10"/>
          <div class="note">10 digits, no dashes</div>
          <div class="field-error" id="err-phone">10-digit phone is required</div>
        </div>
      </div>

      <div class="section-label">Address <span class="optional-badge">Optional</span></div>

      <div class="form-group">
        <label>Street Address</label>
        <input type="text" name="street" placeholder="123 Main St"/>
      </div>
      <div class="form-row-3">
        <div class="form-group">
          <label>City</label>
          <input type="text" name="city" placeholder="Los Angeles"/>
        </div>
        <div class="form-group">
          <label>State</label>
          <select name="state">
            <option value="">—</option>
            <option>AL</option><option>AK</option><option>AZ</option><option>AR</option>
            <option>CA</option><option>CO</option><option>CT</option><option>DE</option>
            <option>FL</option><option>GA</option><option>HI</option><option>ID</option>
            <option>IL</option><option>IN</option><option>IA</option><option>KS</option>
            <option>KY</option><option>LA</option><option>ME</option><option>MD</option>
            <option>MA</option><option>MI</option><option>MN</option><option>MS</option>
            <option>MO</option><option>MT</option><option>NE</option><option>NV</option>
            <option>NH</option><option>NJ</option><option>NM</option><option>NY</option>
            <option>NC</option><option>ND</option><option>OH</option><option>OK</option>
            <option>OR</option><option>PA</option><option>RI</option><option>SC</option>
            <option>SD</option><option>TN</option><option>TX</option><option>UT</option>
            <option>VT</option><option>VA</option><option>WA</option><option>WV</option>
            <option>WI</option><option>WY</option>
          </select>
        </div>
        <div class="form-group">
          <label>Zip</label>
          <input type="text" name="zip" placeholder="90001" maxlength="5"/>
        </div>
      </div>

      <div class="section-label">Compliance <span class="optional-badge">Optional</span></div>

      <div class="form-group">
        <label>TrustedForm Certificate URL</label>
        <input type="text" name="trustedFormCertUrl" placeholder="https://cert.trustedform.com/..."/>
      </div>
      <div class="form-group">
        <label>Jornaya Lead ID</label>
        <input type="text" name="jornayaLeadId" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
      </div>

      <div class="section-label">Tracking <span class="optional-badge">Optional</span></div>

      <div class="form-row">
        <div class="form-group">
          <label>Publisher Sub ID</label>
          <input type="text" name="publisherSub" id="field-publisherSub" placeholder="auto-filled from URL"/>
        </div>
        <div class="form-group">
          <label>Facebook Lead ID</label>
          <input type="text" name="facebookLeadId" placeholder="123456789"/>
        </div>
      </div>

      <div class="form-group">
        <label>Notes</label>
        <textarea name="notes" rows="2" placeholder="Any additional case notes..."></textarea>
      </div>

      <button type="submit" class="submit-btn" id="submit-btn">Submit Lead</button>
      <div class="result" id="result"></div>
    </form>
  </div>
</div>

<!-- POSTING INSTRUCTIONS MODAL -->
<div class="modal-overlay" id="instructions-modal">
  <div class="modal">
    <div class="modal-hdr">
      <h2>📋 DEPO Campaign — Posting Instructions</h2>
      <button class="modal-x" onclick="closeInstructions()">×</button>
    </div>
    <div class="modal-body">
      <div class="instructions-box" id="instructions-text"></div>
      <button class="copy-btn" id="copy-btn" onclick="copyInstructions()">Copy to Clipboard</button>
    </div>
  </div>
</div>

<script>
  /* ══════════════════════════════════════════════════════
     FILE: index.html
     UPLOAD TO: GitHub repo "depo" (krwmarketingsolutions/depo)
     RESULT URL: https://krwmarketingsolutions.github.io/depo
     PURPOSE: DEPO-specific form with posting instructions
     USAGE: ?sub=K002
  ══════════════════════════════════════════════════════ */
  var API_URL = 'https://krw-backend-production.up.railway.app/lead/depo';
  var API_KEY = 'krwleads2026secure';

  var params   = new URLSearchParams(window.location.search);
  var pubSub   = params.get('sub') || params.get('pub') || '';
  var websource= window.location.href;

  var form   = document.getElementById('lead-form');
  var btn    = document.getElementById('submit-btn');
  var result = document.getElementById('result');

  // Pre-fill sub from URL
  if(pubSub){
    var sf = document.getElementById('field-publisherSub');
    if(sf) sf.value = pubSub;
  }

  // Phone: digits only
  form.phone.addEventListener('input', function(){
    this.value = this.value.replace(/\D/g,'').slice(0,10);
    clearErr('phone');
  });

  // Clear errors on type
  ['firstName','lastName','email'].forEach(function(n){
    var el = form.elements[n];
    if(el) el.addEventListener('input', function(){ clearErr(n); });
  });

  function clearErr(name){
    var el  = form.elements[name];
    var err = document.getElementById('err-'+name);
    if(el)  el.classList.remove('invalid');
    if(err) err.classList.remove('show');
  }

  function showErr(name, msg){
    var el  = form.elements[name];
    var err = document.getElementById('err-'+name);
    if(el)  el.classList.add('invalid');
    if(err){ if(msg) err.textContent=msg; err.classList.add('show'); }
  }

  function validate(){
    var ok = true;
    // Clear all
    form.querySelectorAll('.invalid').forEach(function(e){ e.classList.remove('invalid'); });
    form.querySelectorAll('.field-error.show').forEach(function(e){ e.classList.remove('show'); });

    // Required
    if(!form.firstName.value.trim()){ showErr('firstName'); ok=false; }
    if(!form.lastName.value.trim()) { showErr('lastName');  ok=false; }

    var email = form.email.value.trim();
    if(!email){ showErr('email','Email is required'); ok=false; }
    else if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){ showErr('email','Enter a valid email address'); ok=false; }

    var phone = form.phone.value.replace(/\D/g,'');
    if(phone.length < 10){ showErr('phone','Phone must be 10 digits'); ok=false; }

    return ok;
  }

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    if(!validate()){
      var first = form.querySelector('.invalid');
      if(first) first.scrollIntoView({behavior:'smooth',block:'center'});
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting...';
    result.style.display = 'none';

    var data = {
      firstName:          form.firstName.value.trim(),
      lastName:           form.lastName.value.trim(),
      email:              form.email.value.trim(),
      phone:              form.phone.value.replace(/\D/g,''),
      street:             form.street.value.trim()            || undefined,
      city:               form.city.value.trim()              || undefined,
      state:              form.state.value                     || undefined,
      zip:                form.zip.value.trim()                || undefined,
      notes:              form.notes.value.trim()              || undefined,
      trustedFormCertUrl: form.trustedFormCertUrl.value.trim() || undefined,
      jornayaLeadId:      form.jornayaLeadId.value.trim()      || undefined,
      facebookLeadId:     form.facebookLeadId.value.trim()     || undefined,
      publisherSub:       pubSub || form.publisherSub.value.trim() || undefined,
      websource:          websource,
    };

    try{
      var res  = await fetch(API_URL,{method:'POST',headers:{'Content-Type':'application/json','x-api-key':API_KEY},body:JSON.stringify(data)});
      var resp = await res.json();
      if(resp.status==='received'){
        result.className   = 'result success';
        result.textContent = '✓ Lead accepted. Reference ID: '+resp.leadId;
        form.reset();
        if(pubSub && document.getElementById('field-publisherSub'))
          document.getElementById('field-publisherSub').value = pubSub;
      } else {
        result.className   = 'result error';
        result.textContent = '✕ '+(resp.reason||'Submission failed. Check all required fields.');
      }
    } catch(err){
      result.className   = 'result error';
      result.textContent = '✕ Connection error: '+err.message;
    }

    result.style.display = 'block';
    btn.disabled    = false;
    btn.textContent = 'Submit Lead';
  });

  // ── Posting Instructions ──────────────────────────────────────
  function showInstructions(){
    var sub     = pubSub || 'YOUR_SUB_ID';
    var formUrl = window.location.origin + window.location.pathname + '?sub=' + sub;
    var line    = '─'.repeat(52);
    var dline   = '='.repeat(52);

    var txt =
dline+'\n'+
'DEPO CAMPAIGN — PUBLISHER POSTING INSTRUCTIONS\n'+
dline+'\n\n'+
'CAMPAIGN:      DEPO — Mass Tort\n'+
'PUBLISHER ID:  '+sub+'\n'+
'FORM URL:      '+formUrl+'\n\n'+
line+'\n'+
'API ENDPOINT (for programmatic posting)\n'+
line+'\n\n'+
'Method:   POST\n'+
'URL:      '+API_URL+'\n\n'+
'Headers:\n'+
'  Content-Type:  application/json\n'+
'  x-api-key:     '+API_KEY+'\n\n'+
line+'\n'+
'REQUIRED FIELDS  (* must be included)\n'+
line+'\n\n'+
'  firstName *    string    Client first name\n'+
'  lastName  *    string    Client last name\n'+
'  email     *    string    Client email address\n'+
'  phone     *    string    10-digit US phone (digits only)\n\n'+
line+'\n'+
'OPTIONAL FIELDS\n'+
line+'\n\n'+
'  street               string   Street address\n'+
'  city                 string   City\n'+
'  state                string   2-letter state (e.g. CA)\n'+
'  zip                  string   5-digit zip code\n'+
'  notes                string   Case notes\n'+
'  trustedFormCertUrl   string   TrustedForm cert URL\n'+
'  jornayaLeadId        string   Jornaya LeadiD token\n'+
'  facebookLeadId       string   Facebook lead form ID\n'+
'  publisherSub         string   Your sub ID / tracking tag\n\n'+
line+'\n'+
'EXAMPLE PAYLOAD\n'+
line+'\n\n'+
'{\n'+
'  "firstName":    "Jane",\n'+
'  "lastName":     "Smith",\n'+
'  "email":        "jane@gmail.com",\n'+
'  "phone":        "3105550123",\n'+
'  "state":        "CA",\n'+
'  "publisherSub": "'+sub+'"\n'+
'}\n\n'+
line+'\n'+
'RESPONSES\n'+
line+'\n\n'+
'Accepted:  {"status":"received","leadId":"KRW-DEPO-123"}\n'+
'Rejected:  {"status":"rejected","reason":"Missing: phone"}\n\n'+
line+'\n'+
'IMPORTANT NOTES\n'+
line+'\n\n'+
'* Phone: 10 digits only — strip all spaces, dashes, parentheses\n'+
'* Save the leadId from each response for your tracking records\n'+
'* You are responsible for TrustedForm / Jornaya data if required\n'+
'* publisherSub is auto-appended when using the form URL above\n'+
dline;

    document.getElementById('instructions-text').textContent = txt;
    document.getElementById('copy-btn').textContent = 'Copy to Clipboard';
    document.getElementById('copy-btn').classList.remove('copied');
    document.getElementById('instructions-modal').classList.add('open');
  }

  function closeInstructions(){
    document.getElementById('instructions-modal').classList.remove('open');
  }

  function copyInstructions(){
    var text = document.getElementById('instructions-text').textContent;
    navigator.clipboard.writeText(text).then(function(){
      var b = document.getElementById('copy-btn');
      b.textContent='✓ Copied!'; b.classList.add('copied');
      setTimeout(function(){ b.textContent='Copy to Clipboard'; b.classList.remove('copied'); },2500);
    }).catch(function(){
      var ta=document.createElement('textarea');
      ta.value=text; document.body.appendChild(ta); ta.select();
      document.execCommand('copy'); document.body.removeChild(ta);
      document.getElementById('copy-btn').textContent='✓ Copied!';
    });
  }

  document.getElementById('instructions-modal').addEventListener('click',function(e){
    if(e.target===this) closeInstructions();
  });
</script>
</body>
</html>
