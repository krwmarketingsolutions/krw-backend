<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>UNIVERSAL FORM → Upload to GitHub repo "forms" → enables krwmarketingsolutions.github.io/forms</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Helvetica Neue',Arial,sans-serif;background:#f4f4f4;min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:1.5rem 1rem}
  .card{background:white;border-radius:8px;box-shadow:0 2px 16px rgba(0,0,0,.1);width:100%;max-width:540px;overflow:hidden}
  .card-hdr{background:#1a1a2e;color:white;padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:12px}
  .card-hdr-left h1{font-size:16px;font-weight:600;margin-bottom:2px}
  .card-hdr-left p{font-size:12px;opacity:.6}
  .instructions-btn{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);color:white;border-radius:5px;padding:6px 12px;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;transition:background .15s;display:none}
  .instructions-btn:hover{background:rgba(255,255,255,.22)}
  .card-body{padding:1.5rem}
  .loading{text-align:center;padding:2.5rem;color:#999;font-size:14px}
  .error-state{text-align:center;padding:2.5rem;color:#991b1b;font-size:14px}
  .form-group{margin-bottom:14px}
  .form-group label{display:flex;align-items:center;gap:3px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#555;margin-bottom:5px}
  .req{color:#e53e3e;font-size:14px;line-height:1;font-weight:700}
  .form-group input,.form-group select,.form-group textarea{width:100%;padding:9px 12px;border:1px solid #ddd;border-radius:5px;font-size:13px;font-family:inherit;outline:none;transition:border .15s;background:#fafafa;color:#1a1a2e}
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:#2d6a4f;background:white;box-shadow:0 0 0 3px rgba(45,106,79,.08)}
  .form-group input.invalid,.form-group select.invalid{border-color:#e53e3e!important;background:#fff5f5!important}
  .field-error{font-size:11px;color:#e53e3e;margin-top:3px;display:none}
  .field-error.show{display:block}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .form-row-3{display:grid;grid-template-columns:2fr 1fr 1fr;gap:12px}
  .section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#999;margin:20px 0 10px;padding-bottom:5px;border-bottom:1px solid #eee;display:flex;align-items:center;gap:6px}
  .optional-badge{font-size:9px;background:#f0f0f0;color:#aaa;padding:1px 6px;border-radius:10px;font-weight:normal;text-transform:none;letter-spacing:0}
  .note{font-size:11px;color:#aaa;margin-top:4px}
  .submit-btn{width:100%;padding:13px;background:#2d6a4f;color:white;border:none;border-radius:5px;font-size:14px;font-weight:600;cursor:pointer;margin-top:8px;transition:background .15s}
  .submit-btn:hover:not(:disabled){background:#1b4332}
  .submit-btn:disabled{background:#aaa;cursor:not-allowed}
  .result{margin-top:12px;padding:12px 14px;border-radius:5px;font-size:13px;display:none}
  .result.success{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7}
  .result.error{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5}
  /* Modal */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:100;align-items:center;justify-content:center;padding:1rem}
  .modal-overlay.open{display:flex}
  .modal{background:white;border-radius:8px;width:100%;max-width:580px;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.25)}
  .modal-hdr{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;background:#1a1a2e;color:white;border-radius:8px 8px 0 0;position:sticky;top:0}
  .modal-hdr h2{font-size:14px;font-weight:600}
  .modal-x{background:none;border:none;color:white;font-size:22px;cursor:pointer;line-height:1;padding:2px 6px;opacity:.7}
  .modal-x:hover{opacity:1}
  .modal-body{padding:1.25rem}
  .instructions-box{background:#0f172a;color:#e2e8f0;border-radius:6px;padding:1rem;font-family:'Courier New',monospace;font-size:11px;line-height:1.8;white-space:pre;overflow-x:auto;margin-bottom:12px;max-height:60vh;overflow-y:auto}
  .copy-btn{width:100%;padding:11px;background:#2d6a4f;color:white;border:none;border-radius:5px;font-size:13px;font-weight:600;cursor:pointer;transition:background .15s}
  .copy-btn:hover{background:#1b4332}
  .copy-btn.copied{background:#065f46}
</style>
</head>
<body>

<div class="card">
  <div class="card-hdr">
    <div class="card-hdr-left">
      <h1 id="form-title">Loading...</h1>
      <p id="form-subtitle">Lead submission form</p>
    </div>
    <button class="instructions-btn" id="instructions-btn" onclick="showInstructions()">📋 Posting Instructions</button>
  </div>
  <div class="card-body">
    <div class="loading" id="loading-state">Loading form...</div>
    <div class="error-state" id="error-state" style="display:none"></div>
    <form id="lead-form" style="display:none" autocomplete="off" novalidate>
      <div id="form-fields"></div>
      <button type="submit" class="submit-btn" id="submit-btn">Submit Lead</button>
      <div class="result" id="result"></div>
    </form>
  </div>
</div>

<!-- POSTING INSTRUCTIONS MODAL -->
<div class="modal-overlay" id="instructions-modal">
  <div class="modal">
    <div class="modal-hdr">
      <h2 id="modal-title">Posting Instructions</h2>
      <button class="modal-x" onclick="closeInstructions()">×</button>
    </div>
    <div class="modal-body">
      <div class="instructions-box" id="instructions-text"></div>
      <button class="copy-btn" id="copy-btn" onclick="copyInstructions()">Copy to Clipboard</button>
    </div>
  </div>
</div>

<script>
  // ── Config ────────────────────────────────────────────────────
  var API_BASE = 'https://krw-backend-production.up.railway.app';
  var API_KEY  = 'krwleads2026secure';
  // ─────────────────────────────────────────────────────────────

  var params   = new URLSearchParams(window.location.search);
  var campaign = (params.get('campaign') || params.get('c') || 'depo').toLowerCase();
  var pubSub   = params.get('sub') || params.get('pub') || '';
  var websource= window.location.href;

  var campaignConfig = null;

  // Field type hints
  var FIELD_TYPES = {
    email:'email', phone:'tel', zip:'text', state:'select',
    street:'text', city:'text', notes:'textarea',
    trustedFormCertUrl:'text', jornayaLeadId:'text',
    facebookLeadId:'text', publisherSub:'text',
    firstName:'text', lastName:'text',
  };

  var FIELD_PLACEHOLDERS = {
    firstName:'Jane', lastName:'Smith', email:'jane@gmail.com',
    phone:'3105550123', street:'123 Main St', city:'Los Angeles',
    state:'', zip:'90001', notes:'Any additional case notes...',
    trustedFormCertUrl:'https://cert.trustedform.com/...',
    jornayaLeadId:'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx',
    facebookLeadId:'123456789', publisherSub:'auto-filled from URL',
  };

  var STATES = ['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID',
    'IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT',
    'NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC',
    'SD','TN','TX','UT','VT','VA','WA','WV','WI','WY'];

  // ── Load campaign config ──────────────────────────────────────
  async function loadCampaign(){
    try{
      var res = await fetch(API_BASE + '/campaigns/' + campaign + '/config');
      var cfg = await res.json();
      if(!cfg.ok) throw new Error(cfg.error || 'Campaign not found');
      campaignConfig = cfg;
      buildForm(cfg);
    } catch(err){
      document.getElementById('loading-state').style.display = 'none';
      var errEl = document.getElementById('error-state');
      errEl.style.display = '';
      errEl.textContent = '✕ Could not load form: ' + err.message + '. Check the campaign parameter in the URL.';
    }
  }

  // ── Build form dynamically ────────────────────────────────────
  function buildForm(cfg){
    document.getElementById('form-title').textContent = cfg.name;
    document.getElementById('form-subtitle').textContent = cfg.vertical + ' — Lead Submission';
    document.getElementById('modal-title').textContent  = cfg.name + ' — Posting Instructions';
    document.getElementById('instructions-btn').style.display = '';
    document.getElementById('loading-state').style.display = 'none';

    var container = document.getElementById('form-fields');
    container.innerHTML = '';

    // Section: Claimant Info (required fields)
    var reqSection = document.createElement('div');
    reqSection.className = 'section-label';
    reqSection.textContent = 'Claimant Information';
    container.appendChild(reqSection);

    // Render required fields in pairs
    var reqPairs = [['firstName','lastName'],['email','phone']];
    reqPairs.forEach(function(pair){
      var row = document.createElement('div');
      row.className = 'form-row';
      pair.forEach(function(name){
        if(cfg.required.includes(name)){
          row.appendChild(buildField(name, true, cfg));
        }
      });
      // Any remaining required fields not in pairs
      if(row.children.length) container.appendChild(row);
    });
    // Any required fields not in predefined pairs
    var pairedRequired = ['firstName','lastName','email','phone'];
    cfg.required.forEach(function(name){
      if(!pairedRequired.includes(name)){
        container.appendChild(buildField(name, true, cfg));
      }
    });

    // Section: Address (optional)
    var hasAddress = ['street','city','state','zip'].some(function(f){ return cfg.optional.includes(f); });
    if(hasAddress){
      var addrSection = document.createElement('div');
      addrSection.className = 'section-label';
      addrSection.innerHTML = 'Address <span class="optional-badge">Optional</span>';
      container.appendChild(addrSection);
      if(cfg.optional.includes('street')) container.appendChild(buildField('street', false, cfg));
      var cityRow = document.createElement('div');
      cityRow.className = 'form-row-3';
      if(cfg.optional.includes('city'))  cityRow.appendChild(buildField('city',  false, cfg));
      if(cfg.optional.includes('state')) cityRow.appendChild(buildField('state', false, cfg));
      if(cfg.optional.includes('zip'))   cityRow.appendChild(buildField('zip',   false, cfg));
      if(cityRow.children.length) container.appendChild(cityRow);
    }

    // Section: Compliance (optional)
    var hasCompliance = ['trustedFormCertUrl','jornayaLeadId'].some(function(f){ return cfg.optional.includes(f); });
    if(hasCompliance){
      var compSection = document.createElement('div');
      compSection.className = 'section-label';
      compSection.innerHTML = 'Compliance <span class="optional-badge">Optional</span>';
      container.appendChild(compSection);
      if(cfg.optional.includes('trustedFormCertUrl')) container.appendChild(buildField('trustedFormCertUrl', false, cfg));
      if(cfg.optional.includes('jornayaLeadId'))      container.appendChild(buildField('jornayaLeadId',      false, cfg));
    }

    // Section: Tracking (optional)
    var hasTracking = ['facebookLeadId','publisherSub'].some(function(f){ return cfg.optional.includes(f); });
    if(hasTracking){
      var trackSection = document.createElement('div');
      trackSection.className = 'section-label';
      trackSection.innerHTML = 'Tracking <span class="optional-badge">Optional</span>';
      container.appendChild(trackSection);
      var trackRow = document.createElement('div');
      trackRow.className = 'form-row';
      if(cfg.optional.includes('publisherSub'))   trackRow.appendChild(buildField('publisherSub',  false, cfg));
      if(cfg.optional.includes('facebookLeadId')) trackRow.appendChild(buildField('facebookLeadId',false, cfg));
      if(trackRow.children.length) container.appendChild(trackRow);
    }

    // Notes
    if(cfg.optional.includes('notes')){
      var notesSection = document.createElement('div');
      notesSection.className = 'section-label';
      notesSection.innerHTML = 'Notes <span class="optional-badge">Optional</span>';
      container.appendChild(notesSection);
      container.appendChild(buildField('notes', false, cfg));
    }

    // Pre-fill sub
    if(pubSub){
      var subEl = document.getElementById('field-publisherSub');
      if(subEl) subEl.value = pubSub;
    }

    document.getElementById('lead-form').style.display = '';
    setupFormHandlers();
  }

  function buildField(name, required, cfg){
    var label   = (cfg.fieldLabels && cfg.fieldLabels[name]) || name;
    var type    = FIELD_TYPES[name] || 'text';
    var ph      = FIELD_PLACEHOLDERS[name] || '';
    var wrapper = document.createElement('div');
    wrapper.className = 'form-group';

    var lbl = document.createElement('label');
    lbl.textContent = label;
    if(required){
      var req = document.createElement('span');
      req.className = 'req';
      req.textContent = '*';
      lbl.appendChild(req);
    }
    wrapper.appendChild(lbl);

    var input;
    if(type === 'select'){
      input = document.createElement('select');
      var def = document.createElement('option');
      def.value = ''; def.textContent = '—';
      input.appendChild(def);
      STATES.forEach(function(s){ var o=document.createElement('option'); o.value=s; o.textContent=s; input.appendChild(o); });
    } else if(type === 'textarea'){
      input = document.createElement('textarea');
      input.rows = 2;
      input.placeholder = ph;
    } else {
      input = document.createElement('input');
      input.type = type;
      input.placeholder = ph;
      if(name === 'phone') input.maxLength = 10;
      if(name === 'zip')   input.maxLength = 5;
    }
    input.name = name;
    input.id   = 'field-' + name;
    if(required) input.dataset.required = 'true';
    wrapper.appendChild(input);

    if(name === 'phone'){
      var note = document.createElement('div');
      note.className = 'note';
      note.textContent = '10 digits, no dashes';
      wrapper.appendChild(note);
    }

    var errDiv = document.createElement('div');
    errDiv.className = 'field-error';
    errDiv.id = 'err-' + name;
    errDiv.textContent = label + ' is required';
    wrapper.appendChild(errDiv);

    return wrapper;
  }

  // ── Form handlers ─────────────────────────────────────────────
  function setupFormHandlers(){
    var form = document.getElementById('lead-form');

    // Phone digits only
    var phoneEl = document.getElementById('field-phone');
    if(phoneEl){
      phoneEl.addEventListener('input', function(){
        this.value = this.value.replace(/\D/g,'').slice(0,10);
        clearErr('phone');
      });
    }

    // Clear errors on input
    form.querySelectorAll('input, select, textarea').forEach(function(el){
      el.addEventListener('input',  function(){ clearErr(this.name); });
      el.addEventListener('change', function(){ clearErr(this.name); });
    });

    form.addEventListener('submit', handleSubmit);
  }

  function clearErr(name){
    var el  = document.getElementById('field-'+name);
    var err = document.getElementById('err-'+name);
    if(el)  el.classList.remove('invalid');
    if(err) err.classList.remove('show');
  }

  function showErr(name, msg){
    var el  = document.getElementById('field-'+name);
    var err = document.getElementById('err-'+name);
    if(el)  el.classList.add('invalid');
    if(err){ if(msg) err.textContent=msg; err.classList.add('show'); }
  }

  function validate(){
    var ok = true;
    document.querySelectorAll('.invalid').forEach(function(e){ e.classList.remove('invalid'); });
    document.querySelectorAll('.field-error.show').forEach(function(e){ e.classList.remove('show'); });

    if(!campaignConfig) return false;

    campaignConfig.required.forEach(function(name){
      var el  = document.getElementById('field-'+name);
      var val = el ? el.value.trim() : '';
      if(!val){ showErr(name); ok=false; }
    });

    var emailEl = document.getElementById('field-email');
    if(emailEl && emailEl.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())){
      showErr('email','Enter a valid email address'); ok=false;
    }

    var phoneEl = document.getElementById('field-phone');
    if(phoneEl && phoneEl.value.replace(/\D/g,'').length < 10){
      showErr('phone','Phone must be 10 digits'); ok=false;
    }

    return ok;
  }

  async function handleSubmit(e){
    e.preventDefault();
    if(!validate()){
      var first = document.querySelector('.invalid');
      if(first) first.scrollIntoView({behavior:'smooth',block:'center'});
      return;
    }

    var btn    = document.getElementById('submit-btn');
    var result = document.getElementById('result');
    btn.disabled = true;
    btn.textContent = 'Submitting...';
    result.style.display = 'none';

    // Build payload from all fields
    var data = { websource: websource };
    var allFields = campaignConfig.required.concat(campaignConfig.optional);
    allFields.forEach(function(name){
      var el = document.getElementById('field-'+name);
      if(el){
        var val = el.value.trim();
        if(val) data[name] = val;
      }
    });
    // Override publisherSub with URL param if present
    if(pubSub) data.publisherSub = pubSub;
    // Phone: digits only
    if(data.phone) data.phone = data.phone.replace(/\D/g,'');

    try{
      var res  = await fetch(API_BASE + '/lead/' + campaign, {
        method:  'POST',
        headers: {'Content-Type':'application/json','x-api-key':API_KEY},
        body:    JSON.stringify(data),
      });
      var resp = await res.json();
      if(resp.status === 'received'){
        result.className   = 'result success';
        result.textContent = '✓ Lead accepted. Reference ID: ' + resp.leadId;
        document.getElementById('lead-form').reset();
        if(pubSub && document.getElementById('field-publisherSub'))
          document.getElementById('field-publisherSub').value = pubSub;
      } else {
        result.className   = 'result error';
        result.textContent = '✕ ' + (resp.reason || 'Submission failed. Check all required fields.');
      }
    } catch(err){
      result.className   = 'result error';
      result.textContent = '✕ Connection error: ' + err.message;
    }

    result.style.display = 'block';
    btn.disabled    = false;
    btn.textContent = 'Submit Lead';
  }

  // ── Posting Instructions ──────────────────────────────────────
  function showInstructions(){
    if(!campaignConfig) return;
    var sub     = pubSub || 'YOUR_SUB_ID';
    var formUrl = window.location.origin + window.location.pathname + '?campaign=' + campaign + '&sub=' + sub;
    var apiUrl  = API_BASE + '/lead/' + campaign;
    var line    = '─'.repeat(52);
    var dline   = '='.repeat(52);

    var reqLines = campaignConfig.required.map(function(f){
      var label = (campaignConfig.fieldLabels && campaignConfig.fieldLabels[f]) || f;
      return '  ' + f.padEnd(18) + '* string    ' + label;
    }).join('\n');

    var optLines = campaignConfig.optional.filter(function(f){
      return !['publisherSub'].includes(f);
    }).map(function(f){
      var label = (campaignConfig.fieldLabels && campaignConfig.fieldLabels[f]) || f;
      return '  ' + f.padEnd(20) + 'string    ' + label;
    }).join('\n');

    var examplePayload = '{\n' +
      campaignConfig.required.map(function(f){
        var ex = {firstName:'Jane',lastName:'Smith',email:'jane@gmail.com',phone:'3105550123'};
        return '  "'+f+'": "'+(ex[f]||'example')+'"';
      }).join(',\n') +
      ',\n  "publisherSub": "'+sub+'"\n}';

    var txt =
dline+'\n'+
campaignConfig.name.toUpperCase()+' — PUBLISHER POSTING INSTRUCTIONS\n'+
dline+'\n\n'+
'CAMPAIGN:      '+campaignConfig.name+'\n'+
'VERTICAL:      '+campaignConfig.vertical+'\n'+
'PUBLISHER ID:  '+sub+'\n'+
'FORM URL:      '+formUrl+'\n\n'+
line+'\n'+
'API ENDPOINT\n'+
line+'\n\n'+
'Method:   POST\n'+
'URL:      '+apiUrl+'\n\n'+
'Headers:\n'+
'  Content-Type:  application/json\n'+
'  x-api-key:     '+API_KEY+'\n\n'+
line+'\n'+
'REQUIRED FIELDS  (* must be included or submission will fail)\n'+
line+'\n\n'+
reqLines+'\n\n'+
line+'\n'+
'OPTIONAL FIELDS\n'+
line+'\n\n'+
optLines+'\n\n'+
line+'\n'+
'EXAMPLE PAYLOAD\n'+
line+'\n\n'+
examplePayload+'\n\n'+
line+'\n'+
'RESPONSES\n'+
line+'\n\n'+
'Accepted:  {"status":"received","leadId":"KRW-'+campaign.toUpperCase()+'-123"}\n'+
'Rejected:  {"status":"rejected","reason":"Missing required fields: phone"}\n\n'+
line+'\n'+
'NOTES\n'+
line+'\n\n'+
'* Phone must be 10 digits — strip all formatting before sending\n'+
'* publisherSub auto-appended when using the form URL above\n'+
'* Save the leadId from each response for your own tracking\n'+
'* You are responsible for TrustedForm / Jornaya data\n'+
dline;

    document.getElementById('instructions-text').textContent = txt;
    document.getElementById('copy-btn').textContent = 'Copy to Clipboard';
    document.getElementById('copy-btn').classList.remove('copied');
    document.getElementById('instructions-modal').classList.add('open');
  }

  function closeInstructions(){
    document.getElementById('instructions-modal').classList.remove('open');
  }

  function copyInstructions(){
    var text = document.getElementById('instructions-text').textContent;
    navigator.clipboard.writeText(text).then(function(){
      var b = document.getElementById('copy-btn');
      b.textContent='✓ Copied!'; b.classList.add('copied');
      setTimeout(function(){ b.textContent='Copy to Clipboard'; b.classList.remove('copied'); },2500);
    }).catch(function(){
      var ta=document.createElement('textarea');
      ta.value=text; document.body.appendChild(ta); ta.select();
      document.execCommand('copy'); document.body.removeChild(ta);
      document.getElementById('copy-btn').textContent='✓ Copied!';
    });
  }

  document.getElementById('instructions-modal').addEventListener('click',function(e){
    if(e.target===this) closeInstructions();
  });

  // Load on page ready
  loadCampaign();
</script>
</body>
</html>
